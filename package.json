{
  "name": "core-boilerplate",
  "type": "module",
  "version": "1.14.1",
  "packageManager": "pnpm@11.5.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "setup": "node scripts/setup-wizard.mjs",
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "format": "prettier --write .",
    "type-check": "astro check",
    "check:contrast": "node scripts/contrast-check.mjs",
    "check:config": "node scripts/validate-config.mjs",
    "lint": "eslint .",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "prepare": "husky"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.3",
    "@iconify-json/line-md": "^1.2.16",
    "@tailwindcss/vite": "^4.3.2",
    "astro": "^7.0.6",
    "astro-icon": "^1.1.5",
    "shiki": "^4.3.1",
    "tailwindcss": "^4.3.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@eslint/js": "^10.0.1",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.61.1",
    "@types/wcag-contrast": "^3.0.3",
    "eslint": "^10.6.0",
    "eslint-plugin-astro": "^2.1.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.4",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.10",
    "wcag-contrast": "^3.0.0"
  },
  "lint-staged": {
    "*.{astro,ts,tsx,js,mjs,cjs,json,css,md}": "prettier --write",
    "*.{astro,ts,tsx,js,mjs,cjs}": "eslint --fix"
  }
}
