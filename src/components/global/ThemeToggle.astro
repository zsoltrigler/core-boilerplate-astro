---
import { Icon } from "astro-icon/components"

export interface Props {
  class?: string
}

const { class: className = "" } = Astro.props

// * Manages dark/light mode with localStorage persistence.
// * The sun icon is shown in dark mode; the moon icon is shown in light mode.
// * Both icons are line-md's animated morph pairs — un-hiding an element replays
//   its SMIL animation from the start, which is how the toggle "plays" on click.
---

<button
  data-theme-toggle
  type="button"
  aria-label="Toggle dark/light mode"
  class={[
    "inline-flex h-10 w-10 cursor-pointer items-center justify-center rounded-lg border border-(--color-border-base) bg-(--color-bg-surface) text-(--color-text-base) transition-colors duration-200 hover:bg-(--color-bg-elevated)",
    className,
  ].join(" ")}
>
  <!-- Sun icon — visible in dark mode; plays moon→sun on switch to light -->
  <Icon
    data-icon-sun
    name="line-md:moon-to-sunny-outline-loop-transition"
    width="20"
    height="20"
    aria-hidden="true"
    class="hidden"
  />

  <!-- Moon icon — visible in light mode; plays sun→moon on switch to dark -->
  <Icon
    data-icon-moon
    name="line-md:sunny-outline-to-moon-loop-transition"
    width="20"
    height="20"
    aria-hidden="true"
  />
</button>

<script>
  // * Syncs both icon states for every toggle instance on the page.
  function syncIcons(btn: HTMLElement, isDark: boolean) {
    btn.querySelector("[data-icon-sun]")?.classList.toggle("hidden", !isDark)
    btn.querySelector("[data-icon-moon]")?.classList.toggle("hidden", isDark)
  }

  // * Cache buttons and track theme state to avoid repeated DOM queries on each click.
  const buttons = Array.from(document.querySelectorAll<HTMLElement>("[data-theme-toggle]"))
  let currentIsDark = document.documentElement.classList.contains("dark")

  function applyTheme(theme: "dark" | "light") {
    currentIsDark = theme === "dark"

    // * Suppress all transitions for one frame so the theme switch is instant —
    //   without this, every element's CSS transition fires simultaneously,
    //   causing choppiness on complex pages. The class is removed after one rAF
    //   so hover/focus transitions continue to work normally.
    document.documentElement.classList.add("theme-switching")
    document.documentElement.classList.toggle("dark", currentIsDark)
    localStorage.setItem("theme", theme)
    // * Sync all toggle instances on the page (e.g. mobile + desktop header).
    buttons.forEach((btn) => syncIcons(btn, currentIsDark))
    requestAnimationFrame(() => document.documentElement.classList.remove("theme-switching"))
  }

  buttons.forEach((btn) => {
    if (btn.dataset.themeToggleInit) return
    btn.dataset.themeToggleInit = "1"

    syncIcons(btn, currentIsDark)

    btn.addEventListener("click", () => {
      applyTheme(currentIsDark ? "light" : "dark")
    })
  })
</script>
