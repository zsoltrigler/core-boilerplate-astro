---
// * Manages dark/light mode with localStorage persistence.
// * The sun icon is shown in dark mode; the moon icon is shown in light mode.
---

<button
  data-theme-toggle
  type="button"
  aria-label="Toggle dark/light mode"
  class="inline-flex h-10 w-10 cursor-pointer items-center justify-center rounded-lg border border-(--color-border-base) bg-(--color-bg-surface) text-(--color-text-base) transition-colors duration-200 hover:bg-(--color-bg-elevated)"
>
  <!-- Sun icon — visible in dark mode -->
  <svg
    data-icon-sun
    xmlns="http://www.w3.org/2000/svg"
    width="20"
    height="20"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
    class="hidden"
  >
    <circle cx="12" cy="12" r="4"></circle>

    <path
      d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"
    ></path>
  </svg>

  <!-- Moon icon — visible in light mode -->
  <svg
    data-icon-moon
    xmlns="http://www.w3.org/2000/svg"
    width="20"
    height="20"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"></path>
  </svg>
</button>

<script>
  // * Syncs both icon states for every toggle instance on the page.
  function syncIcons(btn: HTMLElement, isDark: boolean) {
    btn.querySelector("[data-icon-sun]")?.classList.toggle("hidden", !isDark)
    btn.querySelector("[data-icon-moon]")?.classList.toggle("hidden", isDark)
  }

  // * Cache buttons and track theme state to avoid repeated DOM queries on each click.
  const buttons = Array.from(document.querySelectorAll<HTMLElement>("[data-theme-toggle]"))
  let currentIsDark = document.documentElement.classList.contains("dark")

  function applyTheme(theme: "dark" | "light") {
    currentIsDark = theme === "dark"

    const update = () => {
      document.documentElement.classList.toggle("dark", currentIsDark)
      localStorage.setItem("theme", theme)
      // * Sync all toggle instances on the page (e.g. mobile + desktop header).
      buttons.forEach((btn) => syncIcons(btn, currentIsDark))
    }

    // * VTA cross-fades the entire viewport as one GPU-composited operation —
    //   no per-element CSS transitions firing simultaneously on complex pages.
    if (!document.startViewTransition) {
      update()
      return
    }

    document.startViewTransition(update)
  }

  buttons.forEach((btn) => {
    if (btn.dataset.themeToggleInit) return
    btn.dataset.themeToggleInit = "1"

    syncIcons(btn, currentIsDark)

    btn.addEventListener("click", () => {
      applyTheme(currentIsDark ? "light" : "dark")
    })
  })
</script>
