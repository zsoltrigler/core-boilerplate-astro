---
import { Icon } from "astro-icon/components"
import { SITE, NAV_LINKS } from "../../config"

// * Active state for page-style links (e.g. "/blog") — resolved server-side
//   from the current URL, so it's correct on first paint with no JS. Anchor
//   links ("#features") and external links (http://…) never match here;
//   anchors get their active state from the scroll-spy script below instead.
const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/"

function isActivePath(href: string): boolean {
  if (!href.startsWith("/") || href.startsWith("//")) return false
  const normalized = href.replace(/\/$/, "") || "/"
  return normalized === currentPath
}
---

<header
  class="sticky top-0 z-50 w-full border-b border-(--color-border-base) bg-(--color-bg-base)/80 backdrop-blur-sm transition-colors duration-200"
>
  <div class="mx-auto flex h-16 max-w-7xl items-center justify-between px-6">
    <!-- Logo: override with <slot name="logo"> for a custom logo element -->
    <a
      href="/"
      class="flex items-center gap-2 text-lg font-bold tracking-tight text-(--color-text-base) transition-colors hover:text-(--color-brand-primary)"
    >
      {
        Astro.slots.has("logo") ? (
          <slot name="logo" />
        ) : (
          <>
            {SITE.logo && <img src={SITE.logo} alt={SITE.name} class="h-8 w-auto" />}
            {SITE.showName && SITE.name}
          </>
        )
      }
    </a>

    <!-- Right side: nav + optional extra slot + theme toggle + mobile menu button -->
    <div class="flex items-center gap-2">
      <!-- Desktop navigation — hidden on mobile, visible md and up -->
      <nav
        aria-label="Main navigation"
        class="mr-4 hidden items-center gap-6 text-sm font-medium text-(--color-text-muted) md:flex"
      >
        {
          NAV_LINKS.map((link) => {
            const active = isActivePath(link.href)
            return (
              <a
                href={link.href}
                data-nav-link={link.href}
                aria-current={active ? "page" : undefined}
                class={`transition-colors hover:text-(--color-text-base) ${active ? "font-semibold text-(--color-text-base)" : ""}`}
              >
                {link.label}
              </a>
            )
          })
        }
      </nav>

      <!-- Optional slot for extra header actions (e.g. a CTA button) -->
      <slot name="nav-end" />

      <!-- Mobile menu toggle — visible below md breakpoint -->
      <button
        data-mobile-menu-toggle
        type="button"
        aria-label="Open navigation menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
        data-label-open="Open navigation menu"
        data-label-close="Close navigation menu"
        class="inline-flex h-10 w-10 cursor-pointer items-center justify-center rounded-lg border border-(--color-border-base) bg-(--color-bg-surface) text-(--color-text-base) transition-colors duration-200 hover:bg-(--color-bg-elevated) md:hidden"
      >
        <!-- Menu→close animated icon — shown when menu is closed; plays on open -->
        <Icon
          data-icon-menu
          name="line-md:menu-to-close-transition"
          width="20"
          height="20"
          aria-hidden="true"
        />

        <!-- Close→menu animated icon — shown when menu is open; plays on close -->
        <Icon
          data-icon-close
          name="line-md:close-to-menu-transition"
          width="20"
          height="20"
          aria-hidden="true"
          class="hidden"
        />
      </button>
    </div>
  </div>

  <!-- Mobile navigation drawer -->
  <div
    id="mobile-menu"
    data-mobile-menu
    hidden
    class="border-t border-(--color-border-base) bg-(--color-bg-base) md:hidden"
  >
    <nav aria-label="Mobile navigation">
      <ul class="flex flex-col gap-4 px-6 py-4 text-sm font-medium text-(--color-text-muted)">
        {
          NAV_LINKS.map((link) => {
            const active = isActivePath(link.href)
            return (
              <li>
                <a
                  href={link.href}
                  data-mobile-nav-link
                  data-nav-link={link.href}
                  aria-current={active ? "page" : undefined}
                  class={`block transition-colors hover:text-(--color-text-base) ${active ? "font-semibold text-(--color-text-base)" : ""}`}
                >
                  {link.label}
                </a>
              </li>
            )
          })
        }
      </ul>
    </nav>
  </div>
</header>

<script>
  const btn = document.querySelector<HTMLElement>("[data-mobile-menu-toggle]")
  const menu = document.querySelector<HTMLElement>("[data-mobile-menu]")

  if (btn && menu) {
    const { signal } = new AbortController()

    function setOpen(open: boolean) {
      menu!.hidden = !open
      btn!.setAttribute("aria-expanded", String(open))
      btn!.setAttribute("aria-label", open ? btn!.dataset.labelClose! : btn!.dataset.labelOpen!)
      btn!.querySelector("[data-icon-menu]")?.classList.toggle("hidden", open)
      btn!.querySelector("[data-icon-close]")?.classList.toggle("hidden", !open)
    }

    btn.addEventListener("click", () => setOpen(menu.hidden === true), { signal })

    // Close on nav link click (hash / same-page navigation)
    menu.querySelectorAll<HTMLElement>("[data-mobile-nav-link]").forEach((link) => {
      link.addEventListener("click", () => setOpen(false), { signal })
    })

    // Close when the user clicks outside the menu or toggle button
    document.addEventListener(
      "click",
      (e) => {
        if (!btn.contains(e.target as Node) && !menu.contains(e.target as Node)) {
          setOpen(false)
        }
      },
      { signal }
    )
  }
</script>

<script>
  // * Scroll-spy for anchor-style nav links (e.g. "#features") — highlights
  //   whichever section is currently in view. Page-style links ("/blog") get
  //   their active state server-side above; this only ever touches links
  //   whose data-nav-link starts with "#".
  let observer: IntersectionObserver | null = null

  function initScrollSpy() {
    observer?.disconnect()

    const navLinks = Array.from(document.querySelectorAll<HTMLElement>("[data-nav-link]")).filter(
      (link) => link.dataset.navLink?.startsWith("#")
    )
    if (navLinks.length === 0) return

    // * Group all nav-link elements (desktop + mobile both point at the same
    //   hash) so one intersection event can toggle every matching instance.
    const linksByHash = new Map<string, HTMLElement[]>()
    navLinks.forEach((link) => {
      const hash = link.dataset.navLink!
      linksByHash.set(hash, [...(linksByHash.get(hash) ?? []), link])
    })

    function setActive(hash: string) {
      linksByHash.forEach((links, key) => {
        const active = key === hash
        links.forEach((link) => {
          link.classList.toggle("font-semibold", active)
          link.classList.toggle("text-(--color-text-base)", active)
          if (active) link.setAttribute("aria-current", "page")
          else link.removeAttribute("aria-current")
        })
      })
    }

    // * Offset the detection band by the sticky header's real height rather
    //   than a hardcoded value, so it stays correct if a template customizes it.
    const headerHeight = document.querySelector("header")?.offsetHeight ?? 0

    observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) setActive(`#${entry.target.id}`)
        })
      },
      { rootMargin: `-${headerHeight}px 0px -60% 0px`, threshold: 0 }
    )

    linksByHash.forEach((_links, hash) => {
      const section = document.querySelector(hash)
      if (section) observer!.observe(section)
    })
  }

  initScrollSpy()
  // * Re-init after Astro View Transitions.
  document.addEventListener("astro:page-load", initScrollSpy)
</script>
