---
import ThemeToggle from "./ThemeToggle.astro"
import { SITE, NAV_LINKS } from "../../config"
---

<header
  class="sticky top-0 z-50 w-full border-b border-(--color-border-base) bg-(--color-bg-base)/80 backdrop-blur-sm transition-colors duration-200"
>
  <div class="mx-auto flex h-16 max-w-7xl items-center justify-between px-6">
    <!-- Logo: override with <slot name="logo"> for a custom logo element -->
    <a
      href="/"
      class="flex items-center gap-2 text-lg font-bold tracking-tight text-(--color-text-base) transition-colors hover:text-(--color-brand-primary)"
    >
      {
        Astro.slots.has("logo") ? (
          <slot name="logo" />
        ) : (
          <>
            {SITE.logo && <img src={SITE.logo} alt={SITE.name} class="h-8 w-auto" />}
            {SITE.showName && SITE.name}
          </>
        )
      }
    </a>

    <!-- Right side: nav + optional extra slot + theme toggle + mobile menu button -->
    <div class="flex items-center gap-2">
      <!-- Desktop navigation — hidden on mobile, visible md and up -->
      <nav
        aria-label="Main navigation"
        class="mr-4 hidden items-center gap-6 text-sm font-medium text-(--color-text-muted) md:flex"
      >
        {
          NAV_LINKS.map((link) => (
            <a href={link.href} class="transition-colors hover:text-(--color-text-base)">
              {link.label}
            </a>
          ))
        }
      </nav>

      <!-- Optional slot for extra header actions (e.g. a CTA button) -->
      <slot name="nav-end" />

      <ThemeToggle />

      <!-- Mobile menu toggle — visible below md breakpoint -->
      <button
        data-mobile-menu-toggle
        type="button"
        aria-label="Open navigation menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
        data-label-open="Open navigation menu"
        data-label-close="Close navigation menu"
        class="inline-flex h-10 w-10 cursor-pointer items-center justify-center rounded-lg border border-(--color-border-base) bg-(--color-bg-surface) text-(--color-text-base) transition-colors duration-200 hover:bg-(--color-bg-elevated) md:hidden"
      >
        <!-- Hamburger icon — shown when menu is closed -->
        <svg
          data-icon-menu
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <line x1="4" y1="6" x2="20" y2="6"></line>
          <line x1="4" y1="12" x2="20" y2="12"></line>
          <line x1="4" y1="18" x2="20" y2="18"></line>
        </svg>

        <!-- Close icon — shown when menu is open -->
        <svg
          data-icon-close
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
          class="hidden"
        >
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile navigation drawer -->
  <div
    id="mobile-menu"
    data-mobile-menu
    hidden
    class="border-t border-(--color-border-base) bg-(--color-bg-base) md:hidden"
  >
    <nav aria-label="Mobile navigation">
      <ul class="flex flex-col gap-4 px-6 py-4 text-sm font-medium text-(--color-text-muted)">
        {
          NAV_LINKS.map((link) => (
            <li>
              <a
                href={link.href}
                data-mobile-nav-link
                class="block transition-colors hover:text-(--color-text-base)"
              >
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</header>

<script>
  // * WeakMap ties each AbortController to its button so old listeners are
  //   cleaned up when the button is replaced after a View Transition.
  const controllers = new WeakMap<HTMLElement, AbortController>()

  function initMobileMenu() {
    document.querySelectorAll<HTMLElement>("[data-mobile-menu-toggle]").forEach((btn) => {
      // * Abort previous listener for this button before re-attaching.
      controllers.get(btn)?.abort()
      const controller = new AbortController()
      controllers.set(btn, controller)
      const { signal } = controller

      const menu = document.querySelector<HTMLElement>("[data-mobile-menu]")
      if (!menu) return

      function setOpen(open: boolean) {
        menu!.hidden = !open
        btn.setAttribute("aria-expanded", String(open))
        btn.setAttribute("aria-label", open ? btn.dataset.labelClose! : btn.dataset.labelOpen!)
        btn.querySelector("[data-icon-menu]")?.classList.toggle("hidden", open)
        btn.querySelector("[data-icon-close]")?.classList.toggle("hidden", !open)
      }

      btn.addEventListener("click", () => setOpen(menu.hidden), { signal })

      // Close on nav link click (hash / same-page navigation)
      menu.querySelectorAll<HTMLElement>("[data-mobile-nav-link]").forEach((link) => {
        link.addEventListener("click", () => setOpen(false), { signal })
      })

      // Close when the user clicks outside the menu or toggle button
      document.addEventListener(
        "click",
        (e) => {
          if (!btn.contains(e.target as Node) && !menu.contains(e.target as Node)) {
            setOpen(false)
          }
        },
        { signal }
      )
    })
  }

  // * Re-init after every View Transition to re-attach listeners to new DOM nodes.
  initMobileMenu()
  document.addEventListener("astro:page-load", initMobileMenu)
</script>
