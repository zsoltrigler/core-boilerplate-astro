---
import { SITE, SOCIAL_LINKS } from "../../config"

export interface Props {
  class?: string
}

const { class: className = "" } = Astro.props

const currentYear = new Date().getFullYear()
---

<footer
  class={[
    "w-full border-t border-(--color-border-base) bg-(--color-bg-surface) transition-colors duration-200",
    className,
  ].join(" ")}
>
  <div
    class="mx-auto flex max-w-7xl flex-col items-center justify-between gap-4 px-6 py-8 md:flex-row"
  >
    <!-- Copyright: override with <slot name="copyright"> for custom markup -->
    {
      Astro.slots.has("copyright") ? (
        <slot name="copyright" />
      ) : (
        <p class="text-sm text-(--color-text-muted)">
          &copy; {currentYear} {SITE.name}. {SITE.allRightsReserved}
        </p>
      )
    }

    <!-- Social links: override with <slot name="social"> for custom icons -->
    {
      Astro.slots.has("social") ? (
        <slot name="social" />
      ) : (
        // * Only renders the list when SOCIAL_LINKS is not empty.
        SOCIAL_LINKS.length > 0 && (
          <ul class="flex items-center gap-4">
            {SOCIAL_LINKS.map((link) => (
              <li>
                <a
                  href={link.href}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label={link.label}
                  class="text-(--color-text-muted) transition-colors hover:text-(--color-text-base)"
                >
                  {link.icon ? (
                    // ! set:html renders raw SVG strings from config.ts — keep icon values as trusted inline SVG only, never user-supplied input.
                    <Fragment set:html={link.icon} />
                  ) : (
                    <span class="text-sm">{link.platform}</span>
                  )}
                </a>
              </li>
            ))}
          </ul>
        )
      )
    }

    <!-- Default slot for any additional footer content -->
    <slot />
  </div>
</footer>
