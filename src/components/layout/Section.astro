---
export interface Props {
  id?: string
  /** Semantic HTML element to render. Defaults to <section>. */
  as?: "section" | "article" | "aside" | "div"
  class?: string
}

const { id, as: Tag = "section", class: className = "" } = Astro.props
---

<Tag id={id} class={`w-full ${className}`}>
  <slot />
</Tag>
