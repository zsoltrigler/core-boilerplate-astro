---
import Button from "../ui/Button.astro"
import Tooltip from "../ui/Tooltip.astro"
import ShowcaseSection from "./ShowcaseSection.astro"
---

<ShowcaseSection id="tooltip" title="Tooltip">
  <Fragment slot="description">
    CSS-only tooltip — no JS. Shows on hover and keyboard focus. Pass <code
      class="rounded bg-(--color-bg-surface) px-1">tip</code
    > and optionally <code class="rounded bg-(--color-bg-surface) px-1">placement</code>.
  </Fragment>

  <div class="flex flex-wrap items-center justify-center gap-6 p-8">
    <Tooltip tip="Top tooltip (default)">
      <Button variant="secondary" size="sm">Top</Button>
    </Tooltip>

    <Tooltip tip="Bottom tooltip" placement="bottom">
      <Button variant="secondary" size="sm">Bottom</Button>
    </Tooltip>

    <Tooltip tip="Left tooltip" placement="left">
      <Button variant="secondary" size="sm">Left</Button>
    </Tooltip>

    <Tooltip tip="Right tooltip" placement="right">
      <Button variant="secondary" size="sm">Right</Button>
    </Tooltip>

    <Tooltip tip="Keyboard-accessible — try tabbing here">
      <button
        class="rounded-lg border border-(--color-border-base) px-3 py-1.5 text-sm text-(--color-text-muted) outline-none focus:ring-2 focus:ring-(--color-brand-primary)/40"
      >
        Focus me
      </button>
    </Tooltip>
  </div>
</ShowcaseSection>
