---
import Button from "../ui/Button.astro"
import ShowcaseSection from "./ShowcaseSection.astro"
---

<ShowcaseSection id="button" title="Button">
  <Fragment slot="description">
    Renders as <code class="rounded bg-(--color-bg-surface) px-1">&lt;a&gt;</code> when
    <code class="rounded bg-(--color-bg-surface) px-1">href</code> is set, otherwise
    <code class="rounded bg-(--color-bg-surface) px-1">&lt;button&gt;</code>.
  </Fragment>

  <div class="flex flex-col gap-8 p-6">
    <div class="flex flex-col gap-3">
      <p class="text-xs font-semibold tracking-wider text-(--color-text-muted) uppercase">
        Variants
      </p>

      <div class="flex flex-wrap gap-3">
        <Button variant="primary">Primary</Button>
        <Button variant="secondary">Secondary</Button>
        <Button variant="ghost">Ghost</Button>
        <Button variant="danger">Danger</Button>
      </div>
    </div>

    <div class="flex flex-col gap-3">
      <p class="text-xs font-semibold tracking-wider text-(--color-text-muted) uppercase">Sizes</p>

      <div class="flex flex-wrap items-center gap-3">
        <Button variant="primary" size="sm">Small</Button>
        <Button variant="primary" size="md">Medium</Button>
        <Button variant="primary" size="lg">Large</Button>
      </div>
    </div>

    <div class="flex flex-col gap-3">
      <p class="text-xs font-semibold tracking-wider text-(--color-text-muted) uppercase">States</p>

      <div class="flex flex-wrap gap-3">
        <Button variant="primary" disabled>Disabled</Button>
        <Button variant="primary" href="/ui" external>External ↗</Button>
      </div>

      <div class="flex flex-wrap gap-3">
        <Button variant="secondary" fullWidth>Full width</Button>
      </div>
    </div>

    <div class="flex flex-col gap-3">
      <p class="text-xs font-semibold tracking-wider text-(--color-text-muted) uppercase">
        With icons
      </p>

      <div class="flex flex-wrap gap-3">
        <Button variant="primary">
          <svg
            slot="icon-left"
            xmlns="http://www.w3.org/2000/svg"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
            ><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline
              points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg
          >
          Download
        </Button>

        <Button variant="secondary">
          Send
          <svg
            slot="icon-right"
            xmlns="http://www.w3.org/2000/svg"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
            ><line x1="22" y1="2" x2="11" y2="13"></line><polygon points="22 2 15 22 11 13 2 9 22 2"
            ></polygon></svg
          >
        </Button>
      </div>
    </div>
  </div>
</ShowcaseSection>
