---
import Divider from "../ui/Divider.astro"
import ShowcaseSection from "./ShowcaseSection.astro"
---

<ShowcaseSection id="divider" title="Divider">
  <Fragment slot="description">
    Horizontal rule with an optional centered label, or a vertical separator for inline layouts.
  </Fragment>

  <div class="flex flex-col gap-6 p-6">
    <Divider />

    <Divider label="or continue with" />

    <Divider label="Section break" />

    <div class="flex h-8 items-center gap-4">
      <span class="text-sm text-(--color-text-muted)">Left</span>
      <Divider orientation="vertical" />
      <span class="text-sm text-(--color-text-muted)">Middle</span>
      <Divider orientation="vertical" />
      <span class="text-sm text-(--color-text-muted)">Right</span>
    </div>
  </div>
</ShowcaseSection>
