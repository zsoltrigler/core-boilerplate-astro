---
import Spinner from "../ui/Spinner.astro"
import ShowcaseSection from "./ShowcaseSection.astro"
---

<ShowcaseSection id="spinner" title="Spinner">
  <Fragment slot="description">
    SVG arc spinner with <code class="rounded bg-(--color-bg-surface) px-1">animate-spin</code>.
    Inherits color via <code class="rounded bg-(--color-bg-surface) px-1">currentColor</code> — wrap in
    a colored parent or override with a text-color class.
  </Fragment>

  <div class="flex flex-wrap items-center gap-8 p-8">
    <div class="flex items-center gap-4">
      <Spinner size="sm" />
      <Spinner size="md" />
      <Spinner size="lg" />
    </div>

    <div class="flex items-center gap-4">
      <span class="text-(--color-status-success)"><Spinner size="md" /></span>
      <span class="text-(--color-status-warning)"><Spinner size="md" /></span>
      <span class="text-(--color-status-error)"><Spinner size="md" /></span>
    </div>
  </div>
</ShowcaseSection>
