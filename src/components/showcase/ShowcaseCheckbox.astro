---
import Checkbox from "../ui/Checkbox.astro"
import CodeWindow from "../ui/CodeWindow.astro"
---

<section id="checkbox" class="scroll-mt-24 flex flex-col gap-6">
  <div class="flex flex-col gap-2">
    <h2 class="text-2xl font-bold text-(--color-text-base)">Checkbox</h2>

    <p class="text-sm text-(--color-text-muted)">
      Accessible checkbox with label, error state, and disabled support.
    </p>
  </div>

  <CodeWindow label="Checkbox.astro">

    <div class="flex flex-col gap-8 p-6">
      <div class="flex flex-col gap-3">
        <p class="text-xs font-semibold uppercase tracking-wider text-(--color-text-muted)">States</p>

        <div class="flex flex-col gap-3">
          <Checkbox name="check-default" label="Unchecked" />
          <Checkbox name="check-checked" label="Checked" checked />
          <Checkbox name="check-required" label="Required field" required />
          <Checkbox name="check-disabled" label="Disabled" disabled />
          <Checkbox name="check-disabled-checked" label="Disabled and checked" disabled checked />
        </div>
      </div>

      <div class="flex flex-col gap-3">
        <p class="text-xs font-semibold uppercase tracking-wider text-(--color-text-muted)">Error state</p>

        <Checkbox name="check-error" label="I agree to the terms and conditions" error="You must accept the terms to continue." />
      </div>
    </div>
</CodeWindow>
</section>
