---
import Button from "../ui/Button.astro"
import Drawer from "../ui/Drawer.astro"
import ShowcaseSection from "./ShowcaseSection.astro"
---

<ShowcaseSection id="drawer" title="Drawer">
  <Fragment slot="description">
    Slide-in panel based on native <code class="rounded bg-(--color-bg-surface) px-1"
      >&lt;dialog&gt;</code
    > — built-in focus trap and Escape to close. Add <code
      class="rounded bg-(--color-bg-surface) px-1">data-drawer-open="&lt;id&gt;"</code
    > to any trigger element.
  </Fragment>

  <div class="flex flex-wrap gap-3 p-6">
    <Button variant="secondary" data-drawer-open="drawer-right"> Open right drawer </Button>

    <Button variant="secondary" data-drawer-open="drawer-left"> Open left drawer </Button>
  </div>
</ShowcaseSection>

<Drawer id="drawer-right" title="Right Drawer" side="right">
  <div class="flex flex-col gap-4">
    <p class="text-sm text-(--color-text-muted)">
      This drawer slides in from the right. Use it for navigation, filters, or detail panels.
    </p>
    <p class="text-sm text-(--color-text-muted)">
      Close with the × button, Escape, or backdrop click.
    </p>
  </div>
  <Button slot="footer" data-drawer-close variant="secondary" size="md">Cancel</Button>
  <Button slot="footer" variant="primary" size="md">Save</Button>
</Drawer>

<Drawer id="drawer-left" title="Left Drawer" side="left">
  <nav class="flex flex-col gap-1">
    <a
      href="#"
      class="rounded-lg px-3 py-2 text-sm font-medium text-(--color-text-base) hover:bg-(--color-bg-surface)"
      >Dashboard</a
    >
    <a
      href="#"
      class="rounded-lg px-3 py-2 text-sm font-medium text-(--color-text-base) hover:bg-(--color-bg-surface)"
      >Projects</a
    >
    <a
      href="#"
      class="rounded-lg px-3 py-2 text-sm font-medium text-(--color-text-base) hover:bg-(--color-bg-surface)"
      >Settings</a
    >
  </nav>
</Drawer>
