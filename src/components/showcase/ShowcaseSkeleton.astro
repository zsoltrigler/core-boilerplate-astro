---
import Skeleton from "../ui/Skeleton.astro"
import ShowcaseSection from "./ShowcaseSection.astro"
---

<ShowcaseSection id="skeleton" title="Skeleton">
  <Fragment slot="description">
    Pulsing placeholder for loading states. Combine multiple skeletons to match the shape of the
    content being loaded.
  </Fragment>

  <div class="flex flex-col gap-8 p-6">
    <!-- Card skeleton -->
    <div class="flex flex-col gap-3">
      <p class="text-xs font-semibold tracking-wider text-(--color-text-muted) uppercase">
        Card skeleton
      </p>
      <div
        class="flex flex-col gap-3 rounded-xl border border-(--color-border-base) p-5"
        aria-busy="true"
        aria-label="Loading card"
      >
        <Skeleton height="1.25rem" width="60%" />
        <Skeleton height="0.875rem" width="100%" />
        <Skeleton height="0.875rem" width="85%" />
        <Skeleton height="0.875rem" width="70%" />
        <div class="flex gap-2 pt-1">
          <Skeleton height="2rem" width="6rem" rounded="lg" />
          <Skeleton height="2rem" width="5rem" rounded="lg" />
        </div>
      </div>
    </div>

    <!-- Avatar + text skeleton -->
    <div class="flex flex-col gap-3">
      <p class="text-xs font-semibold tracking-wider text-(--color-text-muted) uppercase">
        Profile row skeleton
      </p>
      <div class="flex items-center gap-3">
        <Skeleton height="2.5rem" width="2.5rem" rounded="full" />
        <div class="flex flex-1 flex-col gap-2">
          <Skeleton height="0.875rem" width="40%" />
          <Skeleton height="0.75rem" width="25%" />
        </div>
      </div>
    </div>
  </div>
</ShowcaseSection>
