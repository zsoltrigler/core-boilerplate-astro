---
import Breadcrumb from "../ui/Breadcrumb.astro"
import ShowcaseSection from "./ShowcaseSection.astro"
---

<ShowcaseSection id="breadcrumb" title="Breadcrumb">
  <Fragment slot="description">
    Accessible navigation trail using a <code class="rounded bg-(--color-bg-surface) px-1"
      >&lt;nav aria-label="Breadcrumb"&gt;</code
    > with an ordered list. The last item renders as a <code
      class="rounded bg-(--color-bg-surface) px-1">span</code
    > with <code class="rounded bg-(--color-bg-surface) px-1">aria-current="page"</code>.
  </Fragment>

  <div class="flex flex-col gap-6 p-6">
    <div class="flex flex-col gap-3">
      <p class="text-xs font-semibold tracking-wider text-(--color-text-muted) uppercase">
        Two levels
      </p>

      <Breadcrumb items={[{ label: "Home", href: "/" }, { label: "UI Components" }]} />
    </div>

    <div class="flex flex-col gap-3">
      <p class="text-xs font-semibold tracking-wider text-(--color-text-muted) uppercase">
        Three levels
      </p>

      <Breadcrumb
        items={[
          { label: "Home", href: "/" },
          { label: "Blog", href: "/blog" },
          { label: "Getting started with Astro" },
        ]}
      />
    </div>

    <div class="flex flex-col gap-3">
      <p class="text-xs font-semibold tracking-wider text-(--color-text-muted) uppercase">
        Four levels
      </p>

      <Breadcrumb
        items={[
          { label: "Home", href: "/" },
          { label: "Docs", href: "/docs" },
          { label: "Components", href: "/docs/components" },
          { label: "Breadcrumb" },
        ]}
      />
    </div>
  </div>
</ShowcaseSection>
