---
import Badge from "../ui/Badge.astro";
import Button from "../ui/Button.astro";
import Section from "../layout/Section.astro";
import Container from "../layout/Container.astro";

export interface Props {
  badge?: string;
  heading: string;
  headingAccent: string;
  subheading: string;
  primaryCta: { label: string; href: string };
  secondaryCta?: { label: string; href: string };
}

const { badge, heading, headingAccent, subheading, primaryCta, secondaryCta } = Astro.props;
---

<Section class="flex flex-col items-center justify-center min-h-screen text-center gap-8">
  <Container>
    <div class="flex flex-col items-center gap-8">

      {badge && <Badge pulse>{badge}</Badge>}

      <h1 class="text-5xl font-bold tracking-tight text-(--color-text-base) max-w-3xl md:text-6xl lg:text-7xl">
        {heading}
        <span class="text-(--color-brand-primary)"> {headingAccent}</span>
      </h1>

      <p class="text-xl text-(--color-text-muted) max-w-xl leading-relaxed">
        {subheading}
      </p>

      <div class="flex flex-wrap items-center justify-center gap-4">
        <Button href={primaryCta.href} variant="primary">
          {primaryCta.label}
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </Button>
        {secondaryCta && (
          <Button href={secondaryCta.href} variant="secondary" external={secondaryCta.href.startsWith("http")}>
            {secondaryCta.label}
          </Button>
        )}
      </div>

    </div>
  </Container>
</Section>
