---
export interface Props {
  /** Accordion item heading. */
  title: string
  /** Open by default. */
  open?: boolean
  class?: string
}

const { title, open = false, class: className = "" } = Astro.props
---

<!--
  * Native <details>/<summary> accordion — no JS required.
  * Multiple items can be open simultaneously. Wrap in a parent if you need
  *   exclusive open behaviour and wire via JS.
-->
<details
  open={open}
  class={`group rounded-xl border border-(--color-border-base) bg-(--color-bg-base) [&[open]]:border-(--color-border-strong) ${className}`}
>
  <summary
    class="flex cursor-pointer list-none items-center justify-between gap-4 px-5 py-4 font-medium text-(--color-text-base) transition-colors duration-150 hover:bg-(--color-bg-surface) [&::-webkit-details-marker]:hidden"
  >
    {title}

    <!-- * Chevron rotates 180° when open via group-open Tailwind variant. -->
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="16"
      height="16"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
      class="shrink-0 text-(--color-text-muted) transition-transform duration-200 group-open:rotate-180"
    >
      <path d="m6 9 6 6 6-6"></path>
    </svg>
  </summary>

  <div class="border-t border-(--color-border-base) px-5 py-4 text-sm text-(--color-text-muted)">
    <slot />
  </div>
</details>
