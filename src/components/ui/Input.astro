---
import { ariaDescribedBy } from "../../utils/aria"
import { fieldStateClasses, FIELD_SIZES } from "../../utils/fieldStyles"
import FormField from "./FormField.astro"

export interface Props {
  /** Input type — covers the most common use cases. */
  type?: "text" | "email" | "password" | "search" | "url" | "tel" | "number"
  name: string
  id?: string
  label?: string
  /** Accessible label when no visible label is rendered. */
  "aria-label"?: string
  placeholder?: string
  value?: string | number
  /** Hint text displayed below the input. */
  hint?: string
  /** Error message — switches the input to error state when set. */
  error?: string
  size?: "sm" | "md" | "lg"
  disabled?: boolean
  required?: boolean
  fullWidth?: boolean
  /** Wires the input to a <datalist> id — used by Combobox. */
  list?: string
  autocomplete?: string
  class?: string
}

const {
  type = "text",
  name,
  id,
  label,
  "aria-label": ariaLabel,
  placeholder,
  value,
  hint,
  error,
  size = "md",
  disabled = false,
  required = false,
  fullWidth = false,
  list,
  autocomplete,
  class: className = "",
  ...rest
} = Astro.props

// * id falls back to name so label[for] always resolves even when id is omitted.
const inputId = id ?? name

const base = [
  "w-full border bg-(--color-bg-base) text-(--color-text-base) placeholder:text-(--color-text-muted)",
  fieldStateClasses(error),
  FIELD_SIZES[size],
].join(" ")
---

<FormField
  id={inputId}
  label={label}
  required={required}
  error={error}
  hint={hint}
  fullWidth={fullWidth}
  class={className}
>
  <input
    type={type}
    id={inputId}
    name={name}
    placeholder={placeholder}
    value={value}
    list={list}
    autocomplete={autocomplete}
    aria-label={!label ? ariaLabel : undefined}
    disabled={disabled}
    required={required}
    aria-invalid={error ? "true" : undefined}
    aria-describedby={ariaDescribedBy(inputId, { error, hint })}
    class={base}
    {...rest}
  />
</FormField>
