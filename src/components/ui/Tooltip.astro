---
export interface Props {
  /** Tooltip text to display on hover / focus. */
  tip: string
  placement?: "top" | "bottom" | "left" | "right"
  class?: string
}

const { tip, placement = "top", class: className = "" } = Astro.props

// * Position offsets for each placement direction.
const positions: Record<string, string> = {
  top: "bottom-full left-1/2 -translate-x-1/2 mb-2",
  bottom: "top-full left-1/2 -translate-x-1/2 mt-2",
  left: "right-full top-1/2 -translate-y-1/2 mr-2",
  right: "left-full top-1/2 -translate-y-1/2 ml-2",
}
---

<!--
  * CSS-only tooltip — no JS required.
  * Shows on hover and on keyboard focus-within (group-focus-within).
  * The wrapping span is inline-flex so it doesn't break text flow.
-->
<span class={`group relative inline-flex ${className}`}>
  <slot />
  <span
    role="tooltip"
    class={`pointer-events-none absolute ${positions[placement]} z-50 whitespace-nowrap rounded-md border border-(--color-border-base) bg-(--color-bg-elevated) px-2.5 py-1.5 text-xs font-medium text-(--color-text-base) shadow-sm opacity-0 transition-opacity duration-150 group-hover:opacity-100 group-focus-within:opacity-100`}
  >
    {tip}
  </span>
</span>
