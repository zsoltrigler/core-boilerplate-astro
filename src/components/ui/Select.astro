---
import { ariaDescribedBy } from "../../utils/aria"

export interface Props {
  name: string
  id?: string
  /** Visible label rendered above the select. */
  label?: string
  /** Accessible label when no visible label is rendered. */
  "aria-label"?: string
  /** Placeholder option shown when no value is selected. */
  placeholder?: string
  /** Error message — switches the select to error state when set. */
  error?: string
  /** Hint text displayed below the select. */
  hint?: string
  size?: "sm" | "md" | "lg"
  disabled?: boolean
  required?: boolean
  fullWidth?: boolean
  class?: string
}

const {
  name,
  id,
  label,
  "aria-label": ariaLabel,
  placeholder,
  error,
  hint,
  size = "md",
  disabled = false,
  required = false,
  fullWidth = false,
  class: className = "",
} = Astro.props

// * id falls back to name so label[for] always resolves even when id is omitted.
const selectId = id ?? name

const sizes: Record<string, string> = {
  sm: "h-8  px-3 text-sm  rounded-md",
  md: "h-10 px-4 text-base rounded-lg",
  lg: "h-12 px-5 text-lg  rounded-xl",
}

const base = [
  "w-full border bg-(--color-bg-base) text-(--color-text-base)",
  "outline-none transition-colors duration-200 cursor-pointer",
  "focus:ring-2 focus:ring-(--color-brand-primary)/40 focus:border-(--color-brand-primary)",
  "disabled:opacity-50 disabled:cursor-not-allowed",
  error
    ? "border-(--color-status-error) focus:ring-(--color-status-error)/40 focus:border-(--color-status-error)"
    : "border-(--color-border-base) hover:border-(--color-border-strong)",
  sizes[size],
].join(" ")
---

<div class={`flex flex-col gap-1.5 ${fullWidth ? "w-full" : "w-fit"} ${className}`}>
  {
    label && (
      <label
        for={selectId}
        class={`text-sm font-medium text-(--color-text-base) ${required ? "after:ml-0.5 after:text-(--color-status-error) after:content-['*']" : ""}`}
      >
        {label}
      </label>
    )
  }

  <select
    id={selectId}
    name={name}
    aria-label={!label ? ariaLabel : undefined}
    disabled={disabled}
    required={required}
    aria-invalid={error ? "true" : undefined}
    aria-describedby={ariaDescribedBy(selectId, { error, hint })}
    class={base}
  >
    {placeholder && <option value="" disabled selected>{placeholder}</option>}
    <slot />
  </select>

  {error && (
    <p id={`${selectId}-error`} class="text-sm text-(--color-status-error)" role="alert">
      {error}
    </p>
  )}

  {hint && (
    <p id={`${selectId}-hint`} class="text-sm text-(--color-text-muted)">
      {hint}
    </p>
  )}
</div>
