---
import { Icon } from "astro-icon/components"
import { ariaDescribedBy } from "../../utils/aria"
import { fieldStateClasses, FIELD_SIZES } from "../../utils/fieldStyles"
import FormField from "./FormField.astro"

export interface Props {
  name: string
  id?: string
  /** Visible label rendered above the select. */
  label?: string
  /** Accessible label when no visible label is rendered. */
  "aria-label"?: string
  /** Placeholder option shown when no value is selected. */
  placeholder?: string
  /** Error message — switches the select to error state when set. */
  error?: string
  /** Hint text displayed below the select. */
  hint?: string
  size?: "sm" | "md" | "lg"
  disabled?: boolean
  required?: boolean
  fullWidth?: boolean
  class?: string
}

const {
  name,
  id,
  label,
  "aria-label": ariaLabel,
  placeholder,
  error,
  hint,
  size = "md",
  disabled = false,
  required = false,
  fullWidth = false,
  class: className = "",
} = Astro.props

// * id falls back to name so label[for] always resolves even when id is omitted.
const selectId = id ?? name

// * Native select arrows vary wildly across browsers/OSes and can't be
//   positioned reliably — appearance-none removes it in favour of a
//   custom chevron, matching the one used in Accordion/Dropdown.
// * pr-* overrides FIELD_SIZES' symmetric px-* on the right side only;
//   Tailwind resolves same-property utility conflicts by specificity of
//   the properties they touch, so a single-side override always wins
//   over the shorthand it's paired with.
const iconGap: Record<"sm" | "md" | "lg", string> = {
  sm: "pr-8",
  md: "pr-10",
  lg: "pr-11",
}

const iconOffset: Record<"sm" | "md" | "lg", string> = {
  sm: "right-2.5",
  md: "right-3",
  lg: "right-3.5",
}

const base = [
  "w-full appearance-none border bg-(--color-bg-base) text-(--color-text-base) cursor-pointer",
  fieldStateClasses(error),
  FIELD_SIZES[size],
  iconGap[size],
].join(" ")
---

<FormField
  id={selectId}
  label={label}
  required={required}
  error={error}
  hint={hint}
  fullWidth={fullWidth}
  class={className}
>
  <div class="relative">
    <select
      id={selectId}
      name={name}
      aria-label={!label ? ariaLabel : undefined}
      disabled={disabled}
      required={required}
      aria-invalid={error ? "true" : undefined}
      aria-describedby={ariaDescribedBy(selectId, { error, hint })}
      class={base}
    >
      {
        placeholder && (
          <option value="" disabled selected>
            {placeholder}
          </option>
        )
      }
      <slot />
    </select>

    <Icon
      name="line-md:chevron-down"
      width="16"
      height="16"
      aria-hidden="true"
      class={`pointer-events-none absolute top-1/2 ${iconOffset[size]} -translate-y-1/2 text-(--color-text-muted) ${disabled ? "opacity-50" : ""}`}
    />
  </div>
</FormField>
