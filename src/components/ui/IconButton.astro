---
export interface Props {
  // ! label is required — it becomes the aria-label for screen readers.
  label: string
  href?: string
  type?: "button" | "submit" | "reset"
  variant?: "primary" | "secondary" | "ghost" | "danger"
  size?: "sm" | "md" | "lg"
  /** Opens the link in a new tab with rel="noopener noreferrer". */
  external?: boolean
  /** rel attribute for link mode — e.g. "prev" / "next" for pagination controls. */
  rel?: string
  disabled?: boolean
  /**
   * Sets aria-expanded — pass for toggle buttons (e.g. a menu open/close control).
   * The button also gets a "group" class, so slotted content can react to this
   * state purely in CSS via group-aria-expanded:* variants (e.g. rotate/fade a
   * child icon) — no JS-driven icon-swap bookkeeping needed. The caller's own
   * script only needs to flip the expanded/aria-expanded value at runtime.
   */
  expanded?: boolean
  /** Sets aria-controls — id of the element this button toggles. */
  controls?: string
  class?: string
}

const {
  label,
  href,
  type = "button",
  variant = "ghost",
  size = "md",
  external = false,
  rel,
  disabled = false,
  expanded,
  controls,
  class: className = "",
  ...rest
} = Astro.props

const variants: Record<string, string> = {
  primary:
    "bg-(--color-brand-primary) text-(--color-text-inverted) hover:opacity-90 transition-opacity",
  secondary:
    "border border-(--color-border-base) text-(--color-text-base) hover:bg-(--color-bg-surface) transition-colors",
  ghost:
    "text-(--color-text-muted) hover:text-(--color-text-base) hover:bg-(--color-bg-surface) transition-colors",
  danger:
    "bg-(--color-status-error) text-(--color-text-inverted) dark:text-(--color-bg-base) hover:opacity-90 transition-opacity",
}

// * Fixed square dimensions — use the slot to pass an appropriately sized icon.
const sizes: Record<string, string> = {
  sm: "w-8 h-8 rounded-md",
  md: "w-10 h-10 rounded-lg",
  lg: "w-12 h-12 rounded-xl",
}

const base = [
  "group inline-flex items-center justify-center cursor-pointer",
  "disabled:opacity-50 disabled:pointer-events-none duration-200",
  variants[variant],
  sizes[size],
  className,
].join(" ")

// * Renders as <a> when href is provided, <button> otherwise.
// ! external always forces a safe rel — it isn't overridable via the rel prop.
const externalProps = external
  ? { target: "_blank", rel: "noopener noreferrer" }
  : rel
    ? { rel }
    : {}
---

{
  href ? (
    <a
      href={href}
      class={base}
      aria-label={label}
      aria-expanded={expanded}
      aria-controls={controls}
      {...externalProps}
      {...rest}
    >
      <slot />
    </a>
  ) : (
    <button
      type={type}
      class={base}
      aria-label={label}
      aria-expanded={expanded}
      aria-controls={controls}
      disabled={disabled}
      {...rest}
    >
      <slot />
    </button>
  )
}
