---
export interface Props {
  href?: string
  type?: "button" | "submit" | "reset"
  variant?: "primary" | "secondary" | "ghost" | "danger"
  size?: "sm" | "md" | "lg"
  fullWidth?: boolean
  /** Opens the link in a new tab with rel="noopener noreferrer". */
  external?: boolean
  disabled?: boolean
  class?: string
}

const {
  href,
  type = "button",
  variant = "primary",
  size = "md",
  fullWidth = false,
  external = false,
  disabled = false,
  class: className = "",
  ...rest
} = Astro.props

const variants: Record<string, string> = {
  primary:
    "bg-(--color-brand-primary) text-(--color-text-inverted) hover:opacity-90 transition-opacity",
  secondary:
    "border border-(--color-border-base) text-(--color-text-base) hover:bg-(--color-bg-elevated) transition-colors",
  ghost:
    "text-(--color-text-muted) hover:text-(--color-text-base) hover:bg-(--color-bg-elevated) transition-colors",
  danger:
    "bg-(--color-status-error) text-(--color-text-inverted) dark:text-(--color-bg-base) hover:opacity-90 transition-opacity",
}

const sizes: Record<string, string> = {
  sm: "h-8  px-3 text-sm  gap-1.5 rounded-md",
  md: "h-10 px-5 text-base gap-2  rounded-lg",
  lg: "h-12 px-7 text-lg  gap-2.5 rounded-xl",
}

const base = [
  "inline-flex items-center justify-center font-semibold cursor-pointer",
  "disabled:opacity-50 disabled:pointer-events-none",
  "duration-200",
  fullWidth ? "w-full" : "",
  variants[variant],
  sizes[size],
  className,
].join(" ")

// * Renders as <a> when href is provided, <button> otherwise.
// ! Never pass both href and type together — type is ignored on anchor elements.
// ! <a> does not support the disabled attribute — use aria-disabled + pointer-events-none instead.
const externalProps = external ? { target: "_blank", rel: "noopener noreferrer" } : {}
const disabledLinkProps = disabled ? { "aria-disabled": true as const, tabindex: "-1" } : {}
---

{
  href ? (
    <a
      href={disabled ? undefined : href}
      class={`${base} ${disabled ? "pointer-events-none opacity-50" : ""}`}
      {...externalProps}
      {...disabledLinkProps}
      {...rest}
    >
      <slot name="icon-left" />
      <slot />
      <slot name="icon-right" />
    </a>
  ) : (
    <button type={type} class={base} disabled={disabled} {...rest}>
      <slot name="icon-left" />
      <slot />
      <slot name="icon-right" />
    </button>
  )
}
