---
export interface Props {
  /** Progress value 0–100. */
  value: number
  /** Optional visible label rendered above the bar. */
  label?: string
  /** Show percentage text at the end of the bar label row. */
  showPercent?: boolean
  size?: "sm" | "md" | "lg"
  variant?: "primary" | "success" | "warning" | "error"
  class?: string
}

const {
  value,
  label,
  showPercent = false,
  size = "md",
  variant = "primary",
  class: className = "",
} = Astro.props

// * Clamp to 0–100 so an out-of-range value can't break the layout.
const clamped = Math.min(100, Math.max(0, value))

const tracks: Record<string, string> = {
  sm: "h-1.5",
  md: "h-2.5",
  lg: "h-4",
}

const fills: Record<string, string> = {
  primary: "bg-(--color-brand-primary)",
  success: "bg-(--color-status-success)",
  warning: "bg-(--color-status-warning)",
  error: "bg-(--color-status-error)",
}
---

<div class={`flex flex-col gap-1.5 ${className}`}>
  {
    (label || showPercent) && (
      <div class="flex items-center justify-between">
        {label && <span class="text-sm font-medium text-(--color-text-base)">{label}</span>}
        {showPercent && (
          <span class="text-sm text-(--color-text-muted) tabular-nums">{clamped}%</span>
        )}
      </div>
    )
  }

  <div
    role="progressbar"
    aria-valuenow={clamped}
    aria-valuemin={0}
    aria-valuemax={100}
    aria-label={label ?? `${clamped}%`}
    class={`w-full overflow-hidden rounded-full bg-(--color-bg-elevated) ${tracks[size]}`}
  >
    <div
      class={`h-full rounded-full transition-[width] duration-500 ${fills[variant]}`}
      style={`width: ${clamped}%`}
    >
    </div>
  </div>
</div>
