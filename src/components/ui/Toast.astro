---
// * This component renders the toast container and injects the global toast API.
// * Usage: call window.toast("message", { variant, duration }) from any script.
// * Variants: "info" | "success" | "warning" | "error"
---

<div
  id="toast-container"
  aria-live="polite"
  aria-atomic="false"
  class="pointer-events-none fixed top-4 left-1/2 z-50 flex -translate-x-1/2 flex-col items-center gap-2"
>
</div>

<script>
  type ToastVariant = "info" | "success" | "warning" | "error"

  interface ToastOptions {
    variant?: ToastVariant
    duration?: number
  }

  // * astro-icon's <Icon> only resolves at build time — these toasts are inserted
  //   at runtime via plain DOM APIs, so the line-md SVG markup is embedded as a
  //   string literal here instead (same visual icons as Alert's variants).
  const icons: Record<ToastVariant, string> = {
    info: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" aria-hidden="true"><g fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"><path stroke-dasharray="60" d="M12 3c4.97 0 9 4.03 9 9c0 4.97 -4.03 9 -9 9c-4.97 0 -9 -4.03 -9 -9c0 -4.97 4.03 -9 9 -9Z"><animate fill="freeze" attributeName="stroke-dashoffset" dur="0.6s" values="60;0"/></path><path stroke-dasharray="8" stroke-dashoffset="8" d="M12 7v6"><animate fill="freeze" attributeName="stroke-dashoffset" begin="0.7s" dur="0.2s" to="0"/></path><path stroke-dasharray="4" stroke-dashoffset="4" d="M12 17v0.01"><animate fill="freeze" attributeName="stroke-dashoffset" begin="0.7s" dur="0.2s" to="0"/></path></g></svg>`,
    success: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" aria-hidden="true"><g fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"><path stroke-dasharray="60" d="M3 12c0 -4.97 4.03 -9 9 -9c4.97 0 9 4.03 9 9c0 4.97 -4.03 9 -9 9c-4.97 0 -9 -4.03 -9 -9Z"><animate fill="freeze" attributeName="stroke-dashoffset" dur="0.6s" values="60;0"/></path><path stroke-dasharray="14" stroke-dashoffset="14" d="M8 12l3 3l5 -5"><animate fill="freeze" attributeName="stroke-dashoffset" begin="0.6s" dur="0.2s" to="0"/></path></g></svg>`,
    warning: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" aria-hidden="true"><g fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"><path stroke-dasharray="60" d="M12 3l9 17h-18l9 -17Z"><animate fill="freeze" attributeName="stroke-dashoffset" dur="0.6s" values="60;0"/></path><path stroke-dasharray="6" stroke-dashoffset="6" d="M12 10v4"><animate fill="freeze" attributeName="stroke-dashoffset" begin="0.7s" dur="0.2s" to="0"/></path><path stroke-dasharray="4" stroke-dashoffset="4" d="M12 17v0.01"><animate fill="freeze" attributeName="stroke-dashoffset" begin="0.7s" dur="0.2s" to="0"/></path></g></svg>`,
    error: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" aria-hidden="true"><g fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"><path stroke-dasharray="60" d="M3 12c0 -4.97 4.03 -9 9 -9c4.97 0 9 4.03 9 9c0 4.97 -4.03 9 -9 9c-4.97 0 -9 -4.03 -9 -9Z"><animate fill="freeze" attributeName="stroke-dashoffset" dur="0.6s" values="60;0"/></path><path stroke-dasharray="8" stroke-dashoffset="8" d="M12 12l4 4M12 12l-4 -4M12 12l-4 4M12 12l4 -4"><animate fill="freeze" attributeName="stroke-dashoffset" begin="0.6s" dur="0.2s" to="0"/></path></g></svg>`,
  }

  const variantClasses: Record<ToastVariant, string> = {
    info: "border-(--color-status-info) text-(--color-status-info)",
    success: "border-(--color-status-success) text-(--color-status-success)",
    warning: "border-(--color-status-warning) text-(--color-status-warning)",
    error: "border-(--color-status-error) text-(--color-status-error)",
  }

  function showToast(message: string, { variant = "info", duration = 4000 }: ToastOptions = {}) {
    const container = document.getElementById("toast-container")
    if (!container) return

    const toast = document.createElement("div")
    toast.className = [
      "pointer-events-auto flex items-center gap-3 rounded-lg border bg-(--color-bg-surface) px-4 py-3 shadow-lg",
      "text-sm font-medium",
      "translate-x-0 opacity-100 transition-all duration-300",
      variantClasses[variant],
    ].join(" ")

    // * Build DOM nodes instead of innerHTML to prevent XSS from caller-supplied message strings.
    const iconWrapper = document.createElement("span")
    iconWrapper.innerHTML = icons[variant]

    const label = document.createElement("span")
    label.className = "text-(--color-text-base)"
    label.textContent = message

    toast.appendChild(iconWrapper)
    toast.appendChild(label)
    container.appendChild(toast)

    // * Auto-dismiss after duration ms.
    setTimeout(() => {
      toast.style.opacity = "0"
      toast.style.transform = "translateY(-100%)"
      setTimeout(() => toast.remove(), 300)
    }, duration)
  }

  // * Expose as window.toast so any inline script can call it.
  ;(window as unknown as Record<string, unknown>).toast = showToast
</script>
