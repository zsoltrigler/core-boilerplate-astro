---
// * This component renders the toast container and injects the global toast API.
// * Usage: call window.toast("message", { variant, duration }) from any script.
// * Variants: "info" | "success" | "warning" | "error"
---

<div
  id="toast-container"
  aria-live="polite"
  aria-atomic="false"
  class="pointer-events-none fixed top-4 left-1/2 z-50 flex -translate-x-1/2 flex-col items-center gap-2"
>
</div>

<script>
  type ToastVariant = "info" | "success" | "warning" | "error"

  interface ToastOptions {
    variant?: ToastVariant
    duration?: number
  }

  const icons: Record<ToastVariant, string> = {
    info: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4M12 8h.01"/></svg>`,
    success: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>`,
    warning: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>`,
    error: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>`,
  }

  const variantClasses: Record<ToastVariant, string> = {
    info: "border-(--color-status-info) text-(--color-status-info)",
    success: "border-(--color-status-success) text-(--color-status-success)",
    warning: "border-(--color-status-warning) text-(--color-status-warning)",
    error: "border-(--color-status-error) text-(--color-status-error)",
  }

  function showToast(message: string, { variant = "info", duration = 4000 }: ToastOptions = {}) {
    const container = document.getElementById("toast-container")
    if (!container) return

    const toast = document.createElement("div")
    toast.className = [
      "pointer-events-auto flex items-center gap-3 rounded-lg border bg-(--color-bg-surface) px-4 py-3 shadow-lg",
      "text-sm font-medium",
      "translate-x-0 opacity-100 transition-all duration-300",
      variantClasses[variant],
    ].join(" ")

    toast.innerHTML = `${icons[variant]}<span class="text-(--color-text-base)">${message}</span>`
    container.appendChild(toast)

    // * Auto-dismiss after duration ms.
    setTimeout(() => {
      toast.style.opacity = "0"
      toast.style.transform = "translateY(-100%)"
      setTimeout(() => toast.remove(), 300)
    }, duration)
  }

  // * Expose as window.toast so any inline script can call it.
  ;(window as unknown as Record<string, unknown>).toast = showToast
</script>
