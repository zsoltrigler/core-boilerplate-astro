---
export interface Props {
  size?: "sm" | "md" | "lg"
  /** Screen-reader label — defaults to "Loading". */
  label?: string
  class?: string
}

const { size = "md", label = "Loading", class: className = "" } = Astro.props

const sizes: Record<string, string> = {
  sm: "h-4 w-4",
  md: "h-6 w-6",
  lg: "h-8 w-8",
}
---

<!-- * SVG arc spinner — uses currentColor so it inherits text color. -->
<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="2.5"
  stroke-linecap="round"
  aria-label={label}
  role="status"
  class={`animate-spin text-(--color-brand-primary) ${sizes[size]} ${className}`}
>
  <path d="M21 12a9 9 0 1 1-6.219-8.56"></path>
</svg>
