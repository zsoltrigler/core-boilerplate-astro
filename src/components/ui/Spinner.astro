---
import { Icon } from "astro-icon/components"

export interface Props {
  size?: "sm" | "md" | "lg"
  /** Screen-reader label — defaults to "Loading". */
  label?: string
  class?: string
}

const { size = "md", label = "Loading", class: className = "" } = Astro.props

const sizes: Record<string, string> = {
  sm: "h-4 w-4",
  md: "h-6 w-6",
  lg: "h-8 w-8",
}
---

<!-- * line-md loading icon — self-animating, uses currentColor so it inherits text color. -->
<Icon
  name="line-md:loading-twotone-loop"
  aria-label={label}
  role="status"
  class={`text-(--color-brand-primary) ${sizes[size]} ${className}`}
/>
