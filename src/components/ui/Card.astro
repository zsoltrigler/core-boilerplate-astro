---
export interface Props {
  icon?: string;
  title?: string;
  desc?: string;
  hover?: boolean;
  class?: string;
}

const { icon, title, desc, hover = true, class: className = "" } = Astro.props;
---

<div class={`p-5 rounded-xl border border-(--color-border-base) bg-(--color-bg-surface) transition-colors duration-200 ${hover ? "hover:border-(--color-border-strong)" : ""} ${className}`}>
  {icon && <div class="text-2xl mb-3" aria-hidden="true">{icon}</div>}
  {title && <h3 class="font-semibold text-(--color-text-base) mb-1">{title}</h3>}
  {desc && <p class="text-sm text-(--color-text-muted) leading-relaxed">{desc}</p>}
  <slot />
</div>
