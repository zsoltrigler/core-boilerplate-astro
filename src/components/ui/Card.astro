---
export interface Props {
  title?: string
  desc?: string
  padding?: "sm" | "md" | "lg"
  rounded?: "md" | "lg" | "xl" | "2xl"
  /** Highlight the border on hover — enabled by default. */
  hover?: boolean
  shadow?: boolean
  /** "horizontal" stacks icon left, title+desc right — falls back to vertical below the sm breakpoint. */
  layout?: "vertical" | "horizontal"
  class?: string
}

const {
  title,
  desc,
  padding = "md",
  rounded = "xl",
  hover = true,
  shadow = false,
  layout = "vertical",
  class: className = "",
} = Astro.props

const hasTrailing = Astro.slots.has("trailing")

const paddings: Record<string, string> = {
  sm: "p-3",
  md: "p-5",
  lg: "p-8",
}

const roundeds: Record<string, string> = {
  md: "rounded-md",
  lg: "rounded-lg",
  xl: "rounded-xl",
  "2xl": "rounded-2xl",
}
---

<div
  class={[
    "flex flex-col gap-2",
    "border border-(--color-border-base) bg-(--color-bg-surface) transition-colors duration-200",
    paddings[padding],
    roundeds[rounded],
    hover ? "hover:border-(--color-border-strong)" : "",
    shadow ? "shadow-sm" : "",
    className,
  ].join(" ")}
>
  <!-- * layout="horizontal" groups icon + title/desc into a row from the sm breakpoint up, staying stacked below it. -->
  <div
    class={layout === "horizontal"
      ? "flex flex-col gap-2 sm:flex-row sm:items-start sm:gap-3"
      : "contents"}
  >
    <!-- * Named slot takes priority over the prop — use slot="icon" for custom markup. -->
    {
      Astro.slots.has("icon") && (
        <div class="self-start text-2xl" aria-hidden="true">
          <slot name="icon" />
        </div>
      )
    }

    <div class={layout === "horizontal" ? "flex flex-col gap-2" : "contents"}>
      <!-- * Named slot takes priority over the title prop. -->
      {
        (Astro.slots.has("title") || title) && (
          <div class="self-start font-semibold text-(--color-text-base)">
            {Astro.slots.has("title") ? <slot name="title" /> : title}
          </div>
        )
      }

      <!-- * Named slot takes priority over the desc prop. -->
      {
        (Astro.slots.has("desc") || desc) && (
          <div class="self-start text-sm leading-relaxed text-(--color-text-muted)">
            {Astro.slots.has("desc") ? <slot name="desc" /> : desc}
          </div>
        )
      }
    </div>

    <!-- * Only rendered here in horizontal layout — sits at the row's right edge, e.g. a chevron for clickable rows. -->
    {
      layout === "horizontal" && hasTrailing && (
        <div class="shrink-0 sm:ml-auto sm:self-center">
          <slot name="trailing" />
        </div>
      )
    }
  </div>

  <!-- Default slot for fully custom card content -->
  <slot />

  <!-- * Vertical layout keeps trailing content at the bottom of the card, same as before this slot existed. -->
  {layout === "vertical" && hasTrailing && <slot name="trailing" />}
</div>
