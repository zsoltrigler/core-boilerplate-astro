---
import { Icon } from "astro-icon/components"

export interface Props {
  variant?: "info" | "success" | "warning" | "error"
  /** Alert heading. Use <slot name="title"> for custom markup. */
  title?: string
  /** Renders a dismiss (×) button that removes the alert from the DOM. */
  dismissible?: boolean
  class?: string
}

const { variant = "info", title, dismissible = false, class: className = "" } = Astro.props

const styles: Record<string, { border: string; text: string; bg: string }> = {
  info: {
    border: "border-(--color-status-info)",
    text: "text-(--color-status-info)",
    bg: "bg-(--color-bg-base) dark:bg-(--color-status-info)/10",
  },
  success: {
    border: "border-(--color-status-success)",
    text: "text-(--color-status-success)",
    bg: "bg-(--color-bg-base) dark:bg-(--color-status-success)/10",
  },
  warning: {
    border: "border-(--color-status-warning)",
    text: "text-(--color-status-warning)",
    bg: "bg-(--color-bg-base) dark:bg-(--color-status-warning)/10",
  },
  error: {
    border: "border-(--color-status-error)",
    text: "text-(--color-status-error)",
    bg: "bg-(--color-bg-base) dark:bg-(--color-status-error)/10",
  },
}

// * Default icons — override with <slot name="icon"> for custom icons.
const defaultIcons: Record<string, string> = {
  info: "line-md:alert-circle",
  success: "line-md:confirm-circle",
  warning: "line-md:alert",
  error: "line-md:close-circle",
}

const { border, text, bg } = styles[variant]
---

<div
  role="alert"
  data-alert
  class={`flex items-start gap-3 p-4 rounded-lg border ${border} ${bg} ${className}`}
>
  <!-- Icon: override with <slot name="icon"> for a custom icon -->
  {
    Astro.slots.has("icon") ? (
      <slot name="icon" />
    ) : (
      <Icon
        name={defaultIcons[variant]}
        width="20"
        height="20"
        class={`shrink-0 ${text}`}
        aria-hidden="true"
      />
    )
  }

  <div class="flex flex-1 flex-col gap-1">
    <!-- Title: override with <slot name="title"> for custom markup -->
    {
      (Astro.slots.has("title") || title) && (
        <p class={`text-sm font-semibold ${text}`}>
          {Astro.slots.has("title") ? <slot name="title" /> : title}
        </p>
      )
    }

    <div class="text-sm text-(--color-text-base)">
      <slot />
    </div>
  </div>

  {
    dismissible && (
      <button
        data-alert-dismiss
        type="button"
        aria-label="Dismiss"
        class={`shrink-0 ${text} cursor-pointer transition-opacity hover:opacity-70`}
      >
        <Icon name="line-md:close-small" width="16" height="16" aria-hidden="true" />
      </button>
    )
  }
</div>

<script>
  // * AbortController replaces the brittle window flag — tears down and re-registers
  //   the delegated dismiss listener cleanly on every View Transition.
  let controller: AbortController | null = null

  function initAlerts() {
    controller?.abort()
    controller = new AbortController()

    document.addEventListener(
      "click",
      (e) => {
        const btn = (e.target as HTMLElement).closest<HTMLElement>("[data-alert-dismiss]")
        if (btn) btn.closest("[data-alert]")?.remove()
      },
      { signal: controller.signal }
    )
  }

  initAlerts()
</script>
