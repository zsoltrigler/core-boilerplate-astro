---
import { ariaDescribedBy } from "../../utils/aria"
import { fieldStateClasses } from "../../utils/fieldStyles"
import FormField from "./FormField.astro"

export interface Props {
  name: string
  id?: string
  /** Visible label rendered above the textarea. */
  label?: string
  placeholder?: string
  value?: string
  /** Number of visible text rows. */
  rows?: number
  /** Hint text displayed below the textarea. */
  hint?: string
  /** Error message — switches the textarea to error state when set. */
  error?: string
  disabled?: boolean
  required?: boolean
  fullWidth?: boolean
  class?: string
}

const {
  name,
  id,
  label,
  placeholder,
  value,
  rows = 4,
  hint,
  error,
  disabled = false,
  required = false,
  fullWidth = false,
  class: className = "",
} = Astro.props

// * id falls back to name so label[for] always resolves even when id is omitted.
const textareaId = id ?? name

const base = [
  "w-full rounded-lg border bg-(--color-bg-base) px-4 py-2.5 text-base text-(--color-text-base) placeholder:text-(--color-text-muted)",
  "resize-y",
  fieldStateClasses(error),
].join(" ")
---

<FormField
  id={textareaId}
  label={label}
  required={required}
  error={error}
  hint={hint}
  fullWidth={fullWidth}
  class={className}
>
  <textarea
    id={textareaId}
    name={name}
    rows={rows}
    placeholder={placeholder}
    disabled={disabled}
    required={required}
    aria-invalid={error ? "true" : undefined}
    aria-describedby={ariaDescribedBy(textareaId, { error, hint })}
    class={base}>{value}</textarea
  >
</FormField>
