---
export interface Props {
  name: string
  id?: string
  /** Visible label rendered above the textarea. */
  label?: string
  placeholder?: string
  value?: string
  /** Number of visible text rows. */
  rows?: number
  /** Hint text displayed below the textarea. */
  hint?: string
  /** Error message — switches the textarea to error state when set. */
  error?: string
  disabled?: boolean
  required?: boolean
  fullWidth?: boolean
  class?: string
}

const {
  name,
  id,
  label,
  placeholder,
  value,
  rows = 4,
  hint,
  error,
  disabled = false,
  required = false,
  fullWidth = false,
  class: className = "",
} = Astro.props

// * id falls back to name so label[for] always resolves even when id is omitted.
const textareaId = id ?? name

const base = [
  "w-full rounded-lg border bg-(--color-bg-base) px-4 py-2.5 text-base text-(--color-text-base) placeholder:text-(--color-text-muted)",
  "outline-none transition-colors duration-200 resize-y",
  "focus:ring-2 focus:ring-(--color-brand-primary)/40 focus:border-(--color-brand-primary)",
  "disabled:opacity-50 disabled:cursor-not-allowed",
  error
    ? "border-(--color-status-error) focus:ring-(--color-status-error)/40 focus:border-(--color-status-error)"
    : "border-(--color-border-base) hover:border-(--color-border-strong)",
].join(" ")
---

<div class={`flex flex-col gap-1.5 ${fullWidth ? "w-full" : "w-fit"} ${className}`}>
  {
    label && (
      <label
        for={textareaId}
        class={`text-sm font-medium text-(--color-text-base) ${required ? "after:ml-0.5 after:text-(--color-status-error) after:content-['*']" : ""}`}
      >
        {label}
      </label>
    )
  }

  <textarea
    id={textareaId}
    name={name}
    rows={rows}
    placeholder={placeholder}
    disabled={disabled}
    required={required}
    aria-invalid={error ? "true" : undefined}
    aria-describedby={[error && `${textareaId}-error`, hint && `${textareaId}-hint`].filter((x): x is string => !!x).join(" ") || undefined}
    class={base}
  >{value}</textarea>

  {error && (
    <p id={`${textareaId}-error`} class="text-sm text-(--color-status-error)" role="alert">
      {error}
    </p>
  )}

  {hint && (
    <p id={`${textareaId}-hint`} class="text-sm text-(--color-text-muted)">
      {hint}
    </p>
  )}
</div>
