---
import IconButton from "./IconButton.astro"
import { Icon } from "astro-icon/components"

export interface Props {
  /** Unique id — used to wire the trigger button to this modal via data-modal-open. */
  id: string
  /** Modal heading shown in the header bar. */
  title?: string
  size?: "sm" | "md" | "lg" | "xl"
  class?: string
}

const { id, title, size = "md", class: className = "" } = Astro.props

const sizes: Record<string, string> = {
  sm: "max-w-sm",
  md: "max-w-lg",
  lg: "max-w-2xl",
  xl: "max-w-4xl",
}
---

<!--
  * Native <dialog> element — provides built-in accessibility (role, aria-modal,
    focus trap) without JavaScript polyfills. Open via showModal(), close via close().
-->
<dialog
  id={id}
  data-modal
  class={`w-full rounded-2xl border border-(--color-border-base) bg-(--color-bg-base) p-0 shadow-2xl mx-auto my-auto max-h-[90dvh] backdrop:bg-black/60 backdrop:backdrop-blur-sm open:flex open:flex-col ${sizes[size]} ${className}`}
>
  <!-- * Inner wrapper handles flex layout and overflow clipping separately from
       the dialog element — overflow-hidden on <dialog> would prevent body scroll. -->
  <div class="flex min-h-0 flex-1 flex-col overflow-hidden rounded-2xl">
    <!-- Header -->
    {
      (title || Astro.slots.has("title")) && (
        <div class="flex shrink-0 items-center justify-between border-b border-(--color-border-base) px-6 py-4">
          <h2 class="text-lg font-semibold text-(--color-text-base)">
            {Astro.slots.has("title") ? <slot name="title" /> : title}
          </h2>

          <IconButton data-modal-close label="Close modal" variant="ghost" size="sm">
            <Icon name="line-md:close" width="16" height="16" aria-hidden="true" />
          </IconButton>
        </div>
      )
    }

    <!-- Body -->
    <div class="flex-1 overflow-y-auto px-6 py-5 text-(--color-text-base)">
      <slot />
    </div>

    <!-- Footer -->
    {
      Astro.slots.has("footer") && (
        <div class="flex shrink-0 items-center justify-end gap-3 border-t border-(--color-border-base) px-6 py-4">
          <slot name="footer" />
        </div>
      )
    }
  </div>
</dialog>

<script>
  // * Open: any element with [data-modal-open="<id>"] triggers the matching dialog.
  document.querySelectorAll<HTMLElement>("[data-modal-open]").forEach((trigger) => {
    trigger.addEventListener("click", () => {
      const modal = document.getElementById(trigger.dataset.modalOpen!) as HTMLDialogElement | null
      if (!modal) return
      modal.showModal()
      // ! showModal() does not lock body scroll by default — the page
      //   behind stays scrollable via wheel/touch unless done manually.
      document.documentElement.classList.add("overflow-hidden")
    })
  })

  // * Close: the × button and backdrop clicks close the open dialog.
  document.querySelectorAll<HTMLDialogElement>("[data-modal]").forEach((modal) => {
    modal.querySelectorAll("[data-modal-close]").forEach((btn) => {
      btn.addEventListener("click", () => modal.close())
    })

    // ! Backdrop click — <dialog> fills the viewport when open; clicks outside
    //   the inner panel land on the <dialog> element itself, not its children.
    modal.addEventListener("click", (e) => {
      if (e.target === modal) modal.close()
    })

    // ESC is handled natively by the browser for <dialog> — no extra code needed.

    // * The native "close" event fires however the dialog closes (the × button,
    //   backdrop click, or the browser's own ESC handling) — the safest single
    //   place to unlock scroll.
    modal.addEventListener("close", () => {
      document.documentElement.classList.remove("overflow-hidden")
    })
  })
</script>
