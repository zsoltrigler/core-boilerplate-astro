---
export interface Props {
  variant?: "default" | "primary" | "success" | "warning" | "error" | "info";
  size?: "sm" | "md" | "lg";
  pulse?: boolean;
  class?: string;
}

const {
  variant = "default",
  size = "md",
  pulse = false,
  class: className = "",
} = Astro.props;

const variants: Record<string, string> = {
  default: "bg-(--color-bg-surface) border border-(--color-border-base) text-(--color-text-muted)",
  primary: "bg-(--color-brand-primary)/10 border border-(--color-brand-primary) text-(--color-brand-primary)",
  success: "bg-(--color-status-success)/10 border border-(--color-status-success) text-(--color-status-success)",
  warning: "bg-(--color-status-warning)/10 border border-(--color-status-warning) text-(--color-status-warning)",
  error:   "bg-(--color-status-error)/10 border border-(--color-status-error) text-(--color-status-error)",
  info:    "bg-(--color-status-info)/10 border border-(--color-status-info) text-(--color-status-info)",
};

const sizes: Record<string, string> = {
  sm: "px-2 py-0.5 text-xs gap-1",
  md: "px-3 py-1 text-sm gap-2",
  lg: "px-4 py-1.5 text-base gap-2",
};

const pulseColor: Record<string, string> = {
  default: "bg-(--color-brand-primary)",
  primary: "bg-(--color-brand-primary)",
  success: "bg-(--color-status-success)",
  warning: "bg-(--color-status-warning)",
  error:   "bg-(--color-status-error)",
  info:    "bg-(--color-status-info)",
};
---

<span class={`inline-flex self-start items-center font-medium rounded-full ${variants[variant]} ${sizes[size]} ${className}`}>
  {pulse && (
    <span class={`w-1.5 h-1.5 rounded-full animate-pulse ${pulseColor[variant]}`} aria-hidden="true"></span>
  )}
  <slot />
</span>
