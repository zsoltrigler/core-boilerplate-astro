---
export interface Props {
  variant?: "default" | "primary" | "success" | "warning" | "error" | "info"
  size?: "sm" | "md" | "lg"
  /** Show a pulsing dot before the label — useful for live / status indicators. */
  pulse?: boolean
  class?: string
}

const { variant = "default", size = "md", pulse = false, class: className = "" } = Astro.props

const variants: Record<string, string> = {
  default: "bg-(--color-bg-surface) border border-(--color-border-base) text-(--color-text-muted)",
  primary:
    "bg-(--color-bg-base) dark:bg-(--color-brand-primary)/10 border border-(--color-brand-primary) text-(--color-brand-primary)",
  success:
    "bg-(--color-bg-base) dark:bg-(--color-status-success)/10 border border-(--color-status-success) text-(--color-status-success)",
  warning:
    "bg-(--color-bg-base) dark:bg-(--color-status-warning)/10 border border-(--color-status-warning) text-(--color-status-warning)",
  error:
    "bg-(--color-bg-base) dark:bg-(--color-status-error)/10 border border-(--color-status-error) text-(--color-status-error)",
  info: "bg-(--color-bg-base) dark:bg-(--color-status-info)/10 border border-(--color-status-info) text-(--color-status-info)",
}

const sizes: Record<string, string> = {
  sm: "px-2 py-0.5 text-xs gap-1",
  md: "px-3 py-1 text-sm gap-2",
  lg: "px-4 py-1.5 text-base gap-2",
}

// * Pulse dot color matches the variant so it always passes contrast on its own background.
const pulseColor: Record<string, string> = {
  default: "bg-(--color-brand-primary)",
  primary: "bg-(--color-brand-primary)",
  success: "bg-(--color-status-success)",
  warning: "bg-(--color-status-warning)",
  error: "bg-(--color-status-error)",
  info: "bg-(--color-status-info)",
}
---

<span
  class={`inline-flex items-center font-medium rounded-full ${variants[variant]} ${sizes[size]} ${className}`}
>
  {
    pulse && (
      <!-- Decorative indicator — aria-hidden keeps it out of screen readers -->
      <span
        class={`h-1.5 w-1.5 animate-pulse rounded-full ${pulseColor[variant]}`}
        aria-hidden="true"
      />
    )
  }

  <slot />
</span>
