---
export interface Props {
  pulse?: boolean;
  class?: string;
}

const { pulse = false, class: className = "" } = Astro.props;
---

<span class={`inline-flex items-center gap-2 px-3 py-1 rounded-full text-sm font-medium bg-(--color-bg-surface) border border-(--color-border-base) text-(--color-text-muted) ${className}`}>
  {pulse && (
    <span class="w-2 h-2 rounded-full bg-(--color-brand-primary) animate-pulse" aria-hidden="true"></span>
  )}
  <slot />
</span>
