---
import BaseLayout from "../layouts/BaseLayout.astro"
import Header from "../components/global/Header.astro"
import ThemeToggle from "../components/global/ThemeToggle.astro"
import Footer from "../components/global/Footer.astro"
import Container from "../components/layout/Container.astro"
import ShowcaseSection from "../components/showcase/ShowcaseSection.astro"
import Accordion from "../components/ui/Accordion.astro"
import Alert from "../components/ui/Alert.astro"
import Avatar from "../components/ui/Avatar.astro"
import Badge from "../components/ui/Badge.astro"
import Breadcrumb from "../components/ui/Breadcrumb.astro"
import Button from "../components/ui/Button.astro"
import Card from "../components/ui/Card.astro"
import Checkbox from "../components/ui/Checkbox.astro"
import Combobox from "../components/ui/Combobox.astro"
import CodeWindow from "../components/ui/CodeWindow.astro"
import Divider from "../components/ui/Divider.astro"
import Drawer from "../components/ui/Drawer.astro"
import Dropdown from "../components/ui/Dropdown.astro"
import IconButton from "../components/ui/IconButton.astro"
import Input from "../components/ui/Input.astro"
import Modal from "../components/ui/Modal.astro"
import Pagination from "../components/ui/Pagination.astro"
import Progress from "../components/ui/Progress.astro"
import Select from "../components/ui/Select.astro"
import Skeleton from "../components/ui/Skeleton.astro"
import Spinner from "../components/ui/Spinner.astro"
import Stepper from "../components/ui/Stepper.astro"
import Table from "../components/ui/Table.astro"
import Tabs from "../components/ui/Tabs.astro"
import Textarea from "../components/ui/Textarea.astro"
import Toast from "../components/ui/Toast.astro"
import Toggle from "../components/ui/Toggle.astro"
import Tooltip from "../components/ui/Tooltip.astro"

const frameworks = [
  { value: "astro", label: "Astro" },
  { value: "next", label: "Next.js" },
  { value: "nuxt", label: "Nuxt" },
  { value: "sveltekit", label: "SvelteKit" },
  { value: "remix", label: "Remix" },
  { value: "gatsby", label: "Gatsby" },
]

const countries = [
  { value: "hu", label: "Hungary" },
  { value: "de", label: "Germany" },
  { value: "fr", label: "France" },
  { value: "es", label: "Spain" },
  { value: "it", label: "Italy" },
  { value: "nl", label: "Netherlands" },
  { value: "pl", label: "Poland" },
  { value: "pt", label: "Portugal" },
]

const steps = [
  { label: "Account", description: "Basic info" },
  { label: "Profile", description: "About you" },
  { label: "Review", description: "Check details" },
  { label: "Done", description: "All set" },
]

const components = [
  { id: "accordion", label: "Accordion" },
  { id: "alert", label: "Alert" },
  { id: "avatar", label: "Avatar" },
  { id: "badge", label: "Badge" },
  { id: "breadcrumb", label: "Breadcrumb" },
  { id: "button", label: "Button" },
  { id: "card", label: "Card" },
  { id: "checkbox", label: "Checkbox" },
  { id: "combobox", label: "Combobox" },
  { id: "divider", label: "Divider" },
  { id: "drawer", label: "Drawer" },
  { id: "dropdown", label: "Dropdown" },
  { id: "icon-button", label: "IconButton" },
  { id: "input", label: "Input" },
  { id: "modal", label: "Modal" },
  { id: "pagination", label: "Pagination" },
  { id: "progress", label: "Progress" },
  { id: "select", label: "Select" },
  { id: "skeleton", label: "Skeleton" },
  { id: "spinner", label: "Spinner" },
  { id: "stepper", label: "Stepper" },
  { id: "table", label: "Table" },
  { id: "tabs", label: "Tabs" },
  { id: "textarea", label: "Textarea" },
  { id: "toast", label: "Toast" },
  { id: "toggle", label: "Toggle" },
  { id: "tooltip", label: "Tooltip" },
]
---

<BaseLayout
  title="UI Components"
  description="All available UI components in Core Boilerplate."
  noindex={true}
>
  <Header>
    <Button slot="nav-end" href="/" variant="ghost" size="md">← Back to home</Button>
    <ThemeToggle slot="nav-end" />
  </Header>

  <main id="main-content" class="flex flex-1 flex-col">
    <!-- ── Page header ───────────────────────────────────────────── -->
    <div class="relative overflow-hidden border-b border-(--color-border-base)">
      <!-- Top accent line -->
      <div class="absolute inset-x-0 top-0 h-1 bg-(--color-brand-primary)"></div>

      <!-- Radial glow -->
      <div
        class="pointer-events-none absolute inset-0"
        style="background: radial-gradient(ellipse 60% 80% at 80% 50%, color-mix(in srgb, var(--color-brand-primary) 10%, transparent) 0%, transparent 70%);"
      >
      </div>

      <Container class="relative z-10">
        <div class="grid grid-cols-1 gap-10 py-16 lg:grid-cols-2 lg:items-center">
          <!-- Left: title -->
          <div class="flex flex-col gap-4">
            <div>
              <Badge variant="default">Component library</Badge>
            </div>

            <h1 class="text-4xl font-bold text-(--color-text-base)">UI Components</h1>

            <p class="max-w-md text-(--color-text-muted)">
              Every component available in this boilerplate. Copy, paste, customise.
            </p>
          </div>

          <!-- Right: quick jump links -->
          <div class="hidden lg:block">
            <CodeWindow label="Quick jump">
              <div class="grid grid-cols-2 gap-2 p-4">
                {
                  components.map((c) => (
                    <a
                      href={`#${c.id}`}
                      class="flex items-center gap-2 rounded-lg px-3 py-2 text-sm font-medium text-(--color-text-muted) transition-colors hover:bg-(--color-bg-elevated) hover:text-(--color-text-base)"
                    >
                      <span class="h-1.5 w-1.5 rounded-full bg-(--color-brand-primary)" />
                      {c.label}
                    </a>
                  ))
                }
              </div>
            </CodeWindow>
          </div>
        </div>
      </Container>
    </div>

    <!-- ── Two-column layout ─────────────────────────────────────── -->
    <Container>
      <div class="flex gap-12 py-16">
        <!-- Sidebar -->
        <aside class="hidden w-44 shrink-0 lg:block">
          <nav
            aria-label="Component navigation"
            class="sticky top-24 flex max-h-[calc(100dvh-8rem)] flex-col gap-1 overflow-y-auto overscroll-contain pr-1"
          >
            <p
              class="mb-2 text-xs font-semibold tracking-wider text-(--color-text-muted) uppercase"
            >
              Components
            </p>

            {
              components.map((c) => (
                <a
                  href={`#${c.id}`}
                  class="rounded-lg px-3 py-2 text-sm font-medium text-(--color-text-muted) transition-colors hover:bg-(--color-bg-surface) hover:text-(--color-text-base)"
                >
                  {c.label}
                </a>
              ))
            }
          </nav>
        </aside>

        <!-- Component sections -->
        <div class="flex min-w-0 flex-1 flex-col gap-20">
          <!-- ── Accordion ─────────────────────────────────────────── -->
          <ShowcaseSection id="accordion" title="Accordion">
            <Fragment slot="description">
              Native <code class="rounded bg-(--color-bg-surface) px-1">&lt;details&gt;</code>/<code
                class="rounded bg-(--color-bg-surface) px-1">&lt;summary&gt;</code
              > accordion — no JS. Multiple items can be open simultaneously. Pass <code
                class="rounded bg-(--color-bg-surface) px-1">open</code
              > to expand by default.
            </Fragment>

            <div class="flex flex-col gap-2 p-6">
              <Accordion title="What is Core Boilerplate?" open>
                A production-ready Astro 7 + Tailwind CSS v4 starter with WCAG AA enforced at build
                time, 100/100 Lighthouse scores, and a full UI component library.
              </Accordion>

              <Accordion title="Do I need to credit the author?">
                No — Core Boilerplate is MIT-licensed. Use it in personal and commercial projects
                without attribution.
              </Accordion>

              <Accordion title="Can I add my own components?">
                Absolutely. Every component lives in <code
                  class="rounded bg-(--color-bg-surface) px-1 font-mono text-xs"
                  >src/components/ui/</code
                > — just drop a new <code
                  class="rounded bg-(--color-bg-surface) px-1 font-mono text-xs">.astro</code
                > file there.
              </Accordion>

              <Accordion title="Is dark mode supported?">
                Yes — all color tokens have dark-mode overrides in <code
                  class="rounded bg-(--color-bg-surface) px-1 font-mono text-xs">src/config.ts</code
                >. The <code class="rounded bg-(--color-bg-surface) px-1 font-mono text-xs"
                  >ThemeToggle</code
                > component handles switching.
              </Accordion>
            </div>
          </ShowcaseSection>

          <!-- ── Alert ─────────────────────────────────────────────── -->
          <ShowcaseSection id="alert" title="Alert">
            <Fragment slot="description">
              Contextual feedback messages. Supports custom icon and title via named slots.
            </Fragment>

            <div class="flex flex-col gap-4 p-6">
              <Alert variant="info" title="Information"
                >This is an informational message with some useful context for the user.</Alert
              >
              <Alert variant="success" title="Success"
                >Your changes have been saved successfully.</Alert
              >
              <Alert variant="warning" title="Warning"
                >Please review your input before continuing.</Alert
              >
              <Alert variant="error" title="Error">Something went wrong. Please try again.</Alert>
              <Alert variant="info" title="Dismissible" dismissible
                >Click the × to dismiss this alert.</Alert
              >
              <Alert variant="success">Alert without a title — just body text.</Alert>
            </div>
          </ShowcaseSection>

          <!-- ── Avatar ─────────────────────────────────────────────── -->
          <ShowcaseSection id="avatar" title="Avatar">
            <Fragment slot="description">
              Shows an image when <code class="rounded bg-(--color-bg-surface) px-1">src</code> is
              set; falls back to initials derived from <code
                class="rounded bg-(--color-bg-surface) px-1">alt</code
              > or the explicit <code class="rounded bg-(--color-bg-surface) px-1">initials</code> prop.
              Use <code class="rounded bg-(--color-bg-surface) px-1">shape="square"</code> for app icons.
            </Fragment>

            <div class="flex flex-wrap items-end gap-6 p-6">
              <!-- Sizes -->
              <div class="flex items-end gap-3">
                <Avatar alt="Xavier Small" size="xs" />
                <Avatar alt="Susan M" size="sm" />
                <Avatar alt="John Doe" size="md" />
                <Avatar alt="Rebecca L" size="lg" />
                <Avatar alt="Thomas A" size="xl" />
              </div>

              <!-- Shapes -->
              <div class="flex items-center gap-3">
                <Avatar alt="Circle" size="md" />
                <Avatar alt="Square" size="md" shape="square" />
              </div>

              <!-- Explicit initials -->
              <div class="flex items-center gap-3">
                <Avatar initials="AB" size="md" alt="AB initials" />
                <Avatar initials="?" size="md" alt="Unknown user" />
              </div>
            </div>
          </ShowcaseSection>

          <!-- ── Badge ──────────────────────────────────────────────── -->
          <ShowcaseSection id="badge" title="Badge">
            <Fragment slot="description"
              >Inline label for status, category, or emphasis.</Fragment
            >

            <div class="flex flex-col gap-8 p-6">
              <div class="flex flex-col gap-3">
                <p class="text-xs font-semibold tracking-wider text-(--color-text-muted) uppercase">
                  Variants
                </p>

                <div class="flex flex-wrap gap-2">
                  <Badge variant="default">Default</Badge>
                  <Badge variant="primary">Primary</Badge>
                  <Badge variant="success">Success</Badge>
                  <Badge variant="warning">Warning</Badge>
                  <Badge variant="error">Error</Badge>
                  <Badge variant="info">Info</Badge>
                </div>
              </div>

              <div class="flex flex-col gap-3">
                <p class="text-xs font-semibold tracking-wider text-(--color-text-muted) uppercase"
                  >Sizes</p
                >

                <div class="flex flex-wrap items-center gap-3">
                  <Badge size="sm">Small</Badge>
                  <Badge size="md">Medium</Badge>
                  <Badge size="lg">Large</Badge>
                </div>
              </div>

              <div class="flex flex-col gap-3">
                <p class="text-xs font-semibold tracking-wider text-(--color-text-muted) uppercase">
                  With pulse indicator
                </p>

                <div class="flex flex-wrap gap-3">
                  <Badge variant="primary" pulse>Live</Badge>
                  <Badge variant="success" pulse>Online</Badge>
                  <Badge variant="error" pulse>Alert</Badge>
                  <Badge variant="warning" pulse>Pending</Badge>
                </div>
              </div>
            </div>
          </ShowcaseSection>

          <!-- ── Breadcrumb ──────────────────────────────────────────── -->
          <ShowcaseSection id="breadcrumb" title="Breadcrumb">
            <Fragment slot="description">
              Accessible navigation trail using a <code
                class="rounded bg-(--color-bg-surface) px-1"
                >&lt;nav aria-label="Breadcrumb"&gt;</code
              > with an ordered list. The last item renders as a <code
                class="rounded bg-(--color-bg-surface) px-1">span</code
              > with <code class="rounded bg-(--color-bg-surface) px-1">aria-current="page"</code>.
            </Fragment>

            <div class="flex flex-col gap-6 p-6">
              <div class="flex flex-col gap-3">
                <p
                  class="text-xs font-semibold tracking-wider text-(--color-text-muted) uppercase"
                >
                  Two levels
                </p>

                <Breadcrumb items={[{ label: "Home", href: "/" }, { label: "UI Components" }]} />
              </div>

              <div class="flex flex-col gap-3">
                <p
                  class="text-xs font-semibold tracking-wider text-(--color-text-muted) uppercase"
                >
                  Three levels
                </p>

                <Breadcrumb
                  items={[
                    { label: "Home", href: "/" },
                    { label: "Blog", href: "/blog" },
                    { label: "Getting started with Astro" },
                  ]}
                />
              </div>

              <div class="flex flex-col gap-3">
                <p
                  class="text-xs font-semibold tracking-wider text-(--color-text-muted) uppercase"
                >
                  Four levels
                </p>

                <Breadcrumb
                  items={[
                    { label: "Home", href: "/" },
                    { label: "Docs", href: "/docs" },
                    { label: "Components", href: "/docs/components" },
                    { label: "Breadcrumb" },
                  ]}
                />
              </div>
            </div>
          </ShowcaseSection>

          <!-- ── Button ─────────────────────────────────────────────── -->
          <ShowcaseSection id="button" title="Button">
            <Fragment slot="description">
              Renders as <code class="rounded bg-(--color-bg-surface) px-1">&lt;a&gt;</code> when
              <code class="rounded bg-(--color-bg-surface) px-1">href</code> is set, otherwise
              <code class="rounded bg-(--color-bg-surface) px-1">&lt;button&gt;</code>.
            </Fragment>

            <div class="flex flex-col gap-8 p-6">
              <div class="flex flex-col gap-3">
                <p
                  class="text-xs font-semibold tracking-wider text-(--color-text-muted) uppercase"
                >
                  Variants
                </p>

                <div class="flex flex-wrap gap-3">
                  <Button variant="primary">Primary</Button>
                  <Button variant="secondary">Secondary</Button>
                  <Button variant="ghost">Ghost</Button>
                  <Button variant="danger">Danger</Button>
                </div>
              </div>

              <div class="flex flex-col gap-3">
                <p
                  class="text-xs font-semibold tracking-wider text-(--color-text-muted) uppercase"
                  >Sizes</p
                >

                <div class="flex flex-wrap items-center gap-3">
                  <Button variant="primary" size="sm">Small</Button>
                  <Button variant="primary" size="md">Medium</Button>
                  <Button variant="primary" size="lg">Large</Button>
                </div>
              </div>

              <div class="flex flex-col gap-3">
                <p
                  class="text-xs font-semibold tracking-wider text-(--color-text-muted) uppercase"
                  >States</p
                >

                <div class="flex flex-wrap gap-3">
                  <Button variant="primary" disabled>Disabled</Button>
                  <Button variant="primary" href="/ui" external>External ↗</Button>
                </div>

                <div class="flex flex-wrap gap-3">
                  <Button variant="secondary" fullWidth>Full width</Button>
                </div>
              </div>

              <div class="flex flex-col gap-3">
                <p
                  class="text-xs font-semibold tracking-wider text-(--color-text-muted) uppercase"
                >
                  With icons
                </p>

                <div class="flex flex-wrap gap-3">
                  <Button variant="primary">
                    <svg
                      slot="icon-left"
                      xmlns="http://www.w3.org/2000/svg"
                      width="16"
                      height="16"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      aria-hidden="true"
                      ><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline
                        points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"
                      ></line></svg
                    >
                    Download
                  </Button>

                  <Button variant="secondary">
                    Send
                    <svg
                      slot="icon-right"
                      xmlns="http://www.w3.org/2000/svg"
                      width="16"
                      height="16"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      aria-hidden="true"
                      ><line x1="22" y1="2" x2="11" y2="13"></line><polygon
                        points="22 2 15 22 11 13 2 9 22 2"></polygon></svg
                    >
                  </Button>
                </div>
              </div>
            </div>
          </ShowcaseSection>

          <!-- ── Card ───────────────────────────────────────────────── -->
          <ShowcaseSection id="card" title="Card">
            <Fragment slot="description">
              Flexible content container. <code class="rounded bg-(--color-bg-surface) px-1"
                >title</code
              > and <code class="rounded bg-(--color-bg-surface) px-1">desc</code> accept props or named
              slots. Icon always via <code class="rounded bg-(--color-bg-surface) px-1"
                >slot="icon"</code
              >.
            </Fragment>

            <div class="grid grid-cols-1 gap-4 p-6 sm:grid-cols-2 lg:grid-cols-3">
              <Card title="Default" desc="Hover border enabled by default.">
                <span slot="icon">🎨</span>
              </Card>

              <Card title="With shadow" desc="shadow prop adds a subtle drop shadow." shadow>
                <span slot="icon">⚡</span>
              </Card>

              <Card title="No icon" desc="Icon slot is optional — omit for a cleaner look." />

              <Card title="Large padding" desc="padding=lg gives more breathing room." padding="lg">
                <span slot="icon">📦</span>
              </Card>

              <Card title="Rounded 2xl" desc="rounded prop controls border radius." rounded="2xl">
                <span slot="icon">🔵</span>
              </Card>

              <Card title="No hover" desc="hover=false disables border highlight." hover={false}>
                <span slot="icon">🌙</span>
              </Card>

              <Card padding="md">
                <p class="text-sm text-(--color-text-muted)">
                  Card with only a <strong class="text-(--color-text-base)">default slot</strong> —
                  fully custom content.
                </p>
                <Button variant="primary" size="sm">Action</Button>
              </Card>
            </div>
          </ShowcaseSection>

          <!-- ── Checkbox ───────────────────────────────────────────── -->
          <ShowcaseSection id="checkbox" title="Checkbox">
            <Fragment slot="description">
              Accessible checkbox with label, error state, and disabled support.
            </Fragment>

            <div class="flex flex-col gap-8 p-6">
              <div class="flex flex-col gap-3">
                <p
                  class="text-xs font-semibold tracking-wider text-(--color-text-muted) uppercase"
                  >States</p
                >

                <div class="flex flex-col gap-3">
                  <Checkbox name="check-default" label="Unchecked" />
                  <Checkbox name="check-checked" label="Checked" checked />
                  <Checkbox name="check-required" label="Required field" required />
                  <Checkbox name="check-disabled" label="Disabled" disabled />
                  <Checkbox
                    name="check-disabled-checked"
                    label="Disabled and checked"
                    disabled
                    checked
                  />
                </div>
              </div>

              <div class="flex flex-col gap-3">
                <p
                  class="text-xs font-semibold tracking-wider text-(--color-text-muted) uppercase"
                >
                  Error state
                </p>

                <Checkbox
                  name="check-error"
                  label="I agree to the terms and conditions"
                  error="You must accept the terms to continue."
                />
              </div>
            </div>
          </ShowcaseSection>

          <!-- ── Combobox ───────────────────────────────────────────── -->
          <ShowcaseSection id="combobox" title="Combobox">
            <Fragment slot="description">
              Native <code class="rounded bg-(--color-bg-surface) px-1">&lt;input&gt;</code> + <code
                class="rounded bg-(--color-bg-surface) px-1">&lt;datalist&gt;</code
              > — zero JS, works everywhere. Type to filter suggestions. For fully custom filtering, swap
              the datalist for a JS-driven listbox.
            </Fragment>

            <div class="flex flex-wrap items-start gap-6 p-6">
              <Combobox
                name="framework"
                label="Framework"
                options={frameworks}
                placeholder="Search frameworks…"
              />

              <Combobox
                name="country"
                label="Country"
                options={countries}
                placeholder="Search countries…"
                hint="Start typing to filter the list"
              />

              <Combobox
                name="framework-error"
                label="With error"
                options={frameworks}
                placeholder="Search…"
                error="Please select a valid option"
              />
            </div>
          </ShowcaseSection>

          <!-- ── Divider ────────────────────────────────────────────── -->
          <ShowcaseSection id="divider" title="Divider">
            <Fragment slot="description">
              Horizontal rule with an optional centered label, or a vertical separator for inline
              layouts.
            </Fragment>

            <div class="flex flex-col gap-6 p-6">
              <Divider />

              <Divider label="or continue with" />

              <Divider label="Section break" />

              <div class="flex h-8 items-center gap-4">
                <span class="text-sm text-(--color-text-muted)">Left</span>
                <Divider orientation="vertical" />
                <span class="text-sm text-(--color-text-muted)">Middle</span>
                <Divider orientation="vertical" />
                <span class="text-sm text-(--color-text-muted)">Right</span>
              </div>
            </div>
          </ShowcaseSection>

          <!-- ── Drawer ─────────────────────────────────────────────── -->
          <ShowcaseSection id="drawer" title="Drawer">
            <Fragment slot="description">
              Slide-in panel based on native <code class="rounded bg-(--color-bg-surface) px-1"
                >&lt;dialog&gt;</code
              > — built-in focus trap and Escape to close. Add <code
                class="rounded bg-(--color-bg-surface) px-1"
                >data-drawer-open="&lt;id&gt;"</code
              > to any trigger element.
            </Fragment>

            <div class="flex flex-wrap gap-3 p-6">
              <Button variant="secondary" data-drawer-open="drawer-right">
                Open right drawer
              </Button>

              <Button variant="secondary" data-drawer-open="drawer-left"> Open left drawer </Button>
            </div>
          </ShowcaseSection>

          <!-- ── Dropdown ───────────────────────────────────────────── -->
          <ShowcaseSection id="dropdown" title="Dropdown">
            <Fragment slot="description">
              JS-powered menu panel. Place the trigger in <code
                class="rounded bg-(--color-bg-surface) px-1">slot="trigger"</code
              > and menu items in the default slot. Closes on item click, Escape, and outside click.
            </Fragment>

            <div class="flex flex-wrap items-start gap-6 p-8">
              <Dropdown>
                <Button slot="trigger" variant="secondary" size="md">
                  Actions
                  <svg
                    slot="icon-right"
                    xmlns="http://www.w3.org/2000/svg"
                    width="14"
                    height="14"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                  >
                    <path d="m6 9 6 6 6-6"></path>
                  </svg>
                </Button>

                <div class="flex flex-col">
                  <a
                    href="#"
                    class="flex items-center gap-2.5 rounded-lg px-3 py-2 text-sm text-(--color-text-base) transition-colors hover:bg-(--color-bg-surface)"
                  >
                    Edit
                  </a>
                  <a
                    href="#"
