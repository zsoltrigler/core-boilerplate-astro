---
import BaseLayout from "../layouts/BaseLayout.astro"
import Header from "../components/global/Header.astro"
import Footer from "../components/global/Footer.astro"
import Container from "../components/layout/Container.astro"
import Badge from "../components/ui/Badge.astro"
import Button from "../components/ui/Button.astro"
import CodeWindow from "../components/ui/CodeWindow.astro"
import Toast from "../components/ui/Toast.astro"
import ShowcaseAccordion from "../components/showcase/ShowcaseAccordion.astro"
import ShowcaseAlert from "../components/showcase/ShowcaseAlert.astro"
import ShowcaseAvatar from "../components/showcase/ShowcaseAvatar.astro"
import ShowcaseBadge from "../components/showcase/ShowcaseBadge.astro"
import ShowcaseBreadcrumb from "../components/showcase/ShowcaseBreadcrumb.astro"
import ShowcaseButton from "../components/showcase/ShowcaseButton.astro"
import ShowcaseCard from "../components/showcase/ShowcaseCard.astro"
import ShowcaseCheckbox from "../components/showcase/ShowcaseCheckbox.astro"
import ShowcaseCombobox from "../components/showcase/ShowcaseCombobox.astro"
import ShowcaseDivider from "../components/showcase/ShowcaseDivider.astro"
import ShowcaseDrawer from "../components/showcase/ShowcaseDrawer.astro"
import ShowcaseDropdown from "../components/showcase/ShowcaseDropdown.astro"
import ShowcaseIconButton from "../components/showcase/ShowcaseIconButton.astro"
import ShowcaseInput from "../components/showcase/ShowcaseInput.astro"
import ShowcaseModal from "../components/showcase/ShowcaseModal.astro"
import ShowcasePagination from "../components/showcase/ShowcasePagination.astro"
import ShowcaseProgress from "../components/showcase/ShowcaseProgress.astro"
import ShowcaseSelect from "../components/showcase/ShowcaseSelect.astro"
import ShowcaseSkeleton from "../components/showcase/ShowcaseSkeleton.astro"
import ShowcaseSpinner from "../components/showcase/ShowcaseSpinner.astro"
import ShowcaseStepper from "../components/showcase/ShowcaseStepper.astro"
import ShowcaseTable from "../components/showcase/ShowcaseTable.astro"
import ShowcaseTabs from "../components/showcase/ShowcaseTabs.astro"
import ShowcaseTextarea from "../components/showcase/ShowcaseTextarea.astro"
import ShowcaseToast from "../components/showcase/ShowcaseToast.astro"
import ShowcaseToggle from "../components/showcase/ShowcaseToggle.astro"
import ShowcaseTooltip from "../components/showcase/ShowcaseTooltip.astro"

const components = [
  { id: "accordion", label: "Accordion" },
  { id: "alert", label: "Alert" },
  { id: "avatar", label: "Avatar" },
  { id: "badge", label: "Badge" },
  { id: "breadcrumb", label: "Breadcrumb" },
  { id: "button", label: "Button" },
  { id: "card", label: "Card" },
  { id: "checkbox", label: "Checkbox" },
  { id: "combobox", label: "Combobox" },
  { id: "divider", label: "Divider" },
  { id: "drawer", label: "Drawer" },
  { id: "dropdown", label: "Dropdown" },
  { id: "icon-button", label: "IconButton" },
  { id: "input", label: "Input" },
  { id: "modal", label: "Modal" },
  { id: "pagination", label: "Pagination" },
  { id: "progress", label: "Progress" },
  { id: "select", label: "Select" },
  { id: "skeleton", label: "Skeleton" },
  { id: "spinner", label: "Spinner" },
  { id: "stepper", label: "Stepper" },
  { id: "table", label: "Table" },
  { id: "tabs", label: "Tabs" },
  { id: "textarea", label: "Textarea" },
  { id: "toast", label: "Toast" },
  { id: "toggle", label: "Toggle" },
  { id: "tooltip", label: "Tooltip" },
]
---

<BaseLayout
  title="UI Components"
  description="All available UI components in Core Boilerplate."
  noindex={true}
>
  <Header>
    <Button slot="nav-end" href="/" variant="ghost" size="md">← Back to home</Button>
  </Header>

  <main id="main-content" class="flex flex-1 flex-col">
    <!-- ── Page header ───────────────────────────────────────────── -->
    <div class="relative overflow-hidden border-b border-(--color-border-base)">
      <!-- Top accent line -->
      <div class="absolute inset-x-0 top-0 h-1 bg-(--color-brand-primary)"></div>

      <!-- Radial glow -->
      <div
        class="pointer-events-none absolute inset-0"
        style="background: radial-gradient(ellipse 60% 80% at 80% 50%, color-mix(in srgb, var(--color-brand-primary) 10%, transparent) 0%, transparent 70%);"
      >
      </div>

      <Container class="relative z-10">
        <div class="grid grid-cols-1 gap-10 py-16 lg:grid-cols-2 lg:items-center">
          <!-- Left: title -->
          <div class="flex flex-col gap-4">
            <div>
              <Badge variant="default">Component library</Badge>
            </div>

            <h1 class="text-4xl font-bold text-(--color-text-base)">UI Components</h1>

            <p class="max-w-md text-(--color-text-muted)">
              Every component available in this boilerplate. Copy, paste, customise.
            </p>
          </div>

          <!-- Right: quick jump links -->
          <div class="hidden lg:block">
            <CodeWindow label="Quick jump">
              <div class="grid grid-cols-2 gap-2 p-4">
                {
                  components.map((c) => (
                    <a
                      href={`#${c.id}`}
                      class="flex items-center gap-2 rounded-lg px-3 py-2 text-sm font-medium text-(--color-text-muted) transition-colors hover:bg-(--color-bg-elevated) hover:text-(--color-text-base)"
                    >
                      <span class="h-1.5 w-1.5 rounded-full bg-(--color-brand-primary)" />
                      {c.label}
                    </a>
                  ))
                }
              </div>
            </CodeWindow>
          </div>
        </div>
      </Container>
    </div>

    <!-- ── Two-column layout ─────────────────────────────────────── -->
    <Container>
      <div class="flex gap-12 py-16">
        <!-- Sidebar -->
        <aside class="hidden w-44 shrink-0 lg:block">
          <nav
            aria-label="Component navigation"
            class="sticky top-24 flex max-h-[calc(100dvh-8rem)] flex-col gap-1 overflow-y-auto overscroll-contain pr-1"
          >
            <p
              class="mb-2 text-xs font-semibold tracking-wider text-(--color-text-muted) uppercase"
            >
              Components
            </p>

            {
              components.map((c) => (
                <a
                  href={`#${c.id}`}
                  class="rounded-lg px-3 py-2 text-sm font-medium text-(--color-text-muted) transition-colors hover:bg-(--color-bg-surface) hover:text-(--color-text-base)"
                >
                  {c.label}
                </a>
              ))
            }
          </nav>
        </aside>

        <!-- Component sections -->
        <div class="flex min-w-0 flex-1 flex-col gap-20">
          <ShowcaseAccordion />
          <ShowcaseAlert />
          <ShowcaseAvatar />
          <ShowcaseBadge />
          <ShowcaseBreadcrumb />
          <ShowcaseButton />
          <ShowcaseCard />
          <ShowcaseCheckbox />
          <ShowcaseCombobox />
          <ShowcaseDivider />
          <ShowcaseDrawer />
          <ShowcaseDropdown />
          <ShowcaseIconButton />
          <ShowcaseInput />
          <ShowcaseModal />
          <ShowcasePagination />
          <ShowcaseProgress />
          <ShowcaseSelect />
          <ShowcaseSkeleton />
          <ShowcaseSpinner />
          <ShowcaseStepper />
          <ShowcaseTable />
          <ShowcaseTabs />
          <ShowcaseTextarea />
          <ShowcaseToast />
          <ShowcaseToggle />
          <ShowcaseTooltip />
        </div>
      </div>
    </Container>
  </main>

  <script>
    // * Intersection Observer highlights the active sidebar link as the user scrolls.
    //   AbortController ensures clean re-init after View Transitions.
    let controller: AbortController | null = null

    function initSidebarNav() {
      controller?.abort()
      controller = new AbortController()
      const { signal } = controller

      const links = document.querySelectorAll<HTMLAnchorElement>("aside nav a[href^='#']")
      if (!links.length) return

      const sections = Array.from(links)
        .map((l) => document.querySelector<HTMLElement>(l.getAttribute("href")!))
        .filter(Boolean) as HTMLElement[]

      // * Track active link to update only the previous and next — O(1) instead of O(n).
      let activeLink: HTMLAnchorElement | null = null

      function setActive(id: string) {
        const next = Array.from(links).find((l) => l.getAttribute("href") === `#${id}`) ?? null
        if (next === activeLink) return

        if (activeLink) {
          activeLink.classList.remove("bg-(--color-bg-surface)", "text-(--color-text-base)")
          activeLink.classList.add("text-(--color-text-muted)")
        }
        if (next) {
          next.classList.add("bg-(--color-bg-surface)", "text-(--color-text-base)")
          next.classList.remove("text-(--color-text-muted)")
        }
        activeLink = next
      }

      const observer = new IntersectionObserver(
        (entries) => {
          const visible = entries
            .filter((e) => e.isIntersecting)
            .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top)
          if (visible.length) setActive(visible[0].target.id)
        },
        { rootMargin: "-20% 0px -70% 0px", threshold: 0 }
      )

      sections.forEach((s) => observer.observe(s))

      signal.addEventListener("abort", () => observer.disconnect())
    }

    initSidebarNav()
  </script>

  <Toast />
  <Footer />
</BaseLayout>
