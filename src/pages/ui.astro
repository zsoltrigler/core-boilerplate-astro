                <Textarea
                  name="bio"
                  label="Bio"
                  placeholder="Tell us about yourself…"
                  hint="Maximum 200 characters."
                  rows={3}
                  fullWidth
                />
              </div>

              <div class="flex flex-col gap-3">
                <p
                  class="text-xs font-semibold tracking-wider text-(--color-text-muted) uppercase"
                >
                  Error state
                </p>

                <Textarea
                  name="textarea-error"
                  label="Description"
                  error="Description is required."
                  fullWidth
                />
              </div>

              <div class="flex flex-col gap-3">
                <p
                  class="text-xs font-semibold tracking-wider text-(--color-text-muted) uppercase"
                >
                  Disabled
                </p>

                <Textarea
                  name="textarea-disabled"
                  label="Disabled textarea"
                  value="This content cannot be edited."
                  disabled
                  fullWidth
                />
              </div>
            </div>
          </ShowcaseSection>

          <!-- ── Toast ─────────────────────────────────────────────── -->
          <ShowcaseSection id="toast" title="Toast">
            <Fragment slot="description">
              Non-blocking notification. Add <code class="rounded bg-(--color-bg-surface) px-1"
                >&lt;Toast /&gt;</code
              > once to your layout, then call <code class="rounded bg-(--color-bg-surface) px-1"
                >window.toast("message", {"{ variant }"} )</code
              > from any script. Auto-dismisses after 4 seconds.
            </Fragment>

            <div class="flex flex-col gap-3 p-6">
              <p class="text-xs font-semibold tracking-wider text-(--color-text-muted) uppercase"
                >Variants</p
              >

              <div class="flex flex-wrap gap-3">
                <Button variant="secondary" data-toast="info">Info toast</Button>
                <Button variant="secondary" data-toast="success">Success toast</Button>
                <Button variant="secondary" data-toast="warning">Warning toast</Button>
                <Button variant="secondary" data-toast="error">Error toast</Button>
              </div>
            </div>
          </ShowcaseSection>

          <!-- ── Toggle ─────────────────────────────────────────────── -->
          <ShowcaseSection id="toggle" title="Toggle">
            <Fragment slot="description">
              Checkbox-based switch with custom CSS styling. Fully keyboard-accessible — space bar
              toggles. Use instead of <code class="rounded bg-(--color-bg-surface) px-1"
                >Checkbox</code
              > for on/off settings.
            </Fragment>

            <div class="flex flex-wrap items-start gap-6 p-6">
              <div class="flex flex-col gap-4">
                <Toggle name="t-sm" label="Small" size="sm" />
                <Toggle name="t-md" label="Medium (default)" size="md" />
                <Toggle name="t-lg" label="Large" size="lg" />
              </div>

              <div class="flex flex-col gap-4">
                <Toggle name="t-off" label="Off (default)" />
                <Toggle name="t-on" label="On" checked />
                <Toggle name="t-dis" label="Disabled" disabled />
                <Toggle name="t-dis-on" label="Disabled checked" checked disabled />
              </div>
            </div>
          </ShowcaseSection>

          <!-- ── Tooltip ────────────────────────────────────────────── -->
          <ShowcaseSection id="tooltip" title="Tooltip">
            <Fragment slot="description">
              CSS-only tooltip — no JS. Shows on hover and keyboard focus. Pass <code
                class="rounded bg-(--color-bg-surface) px-1">tip</code
              > and optionally <code class="rounded bg-(--color-bg-surface) px-1">placement</code>.
            </Fragment>

            <div class="flex flex-wrap items-center justify-center gap-6 p-8">
              <Tooltip tip="Top tooltip (default)">
                <Button variant="secondary" size="sm">Top</Button>
              </Tooltip>

              <Tooltip tip="Bottom tooltip" placement="bottom">
                <Button variant="secondary" size="sm">Bottom</Button>
              </Tooltip>

              <Tooltip tip="Left tooltip" placement="left">
                <Button variant="secondary" size="sm">Left</Button>
              </Tooltip>

              <Tooltip tip="Right tooltip" placement="right">
                <Button variant="secondary" size="sm">Right</Button>
              </Tooltip>

              <Tooltip tip="Keyboard-accessible — try tabbing here">
                <button
                  class="rounded-lg border border-(--color-border-base) px-3 py-1.5 text-sm text-(--color-text-muted) outline-none focus:ring-2 focus:ring-(--color-brand-primary)/40"
                >
                  Focus me
                </button>
              </Tooltip>
            </div>
          </ShowcaseSection>
        </div>
      </div>
    </Container>

    <!-- ── Dialogs (viewport-level) ─────────────────────────────── -->
    <Modal id="modal-default" title="Confirm action" size="md">
      <p class="text-(--color-text-muted)">
        Are you sure you want to continue? This action cannot be undone.
      </p>
      <Button slot="footer" variant="secondary" data-modal-close>Cancel</Button>
      <Button slot="footer" variant="danger">Delete</Button>
    </Modal>

    <Modal id="modal-sm" title="Quick note" size="sm">
      <p class="text-(--color-text-muted)">A compact modal for short confirmations or notices.</p>
      <Button slot="footer" variant="primary" data-modal-close>Got it</Button>
    </Modal>

    <Modal id="modal-lg" title="Edit profile" size="lg">
      <div class="flex flex-col gap-4">
        <Input name="modal-name" label="Full name" placeholder="Jane Doe" fullWidth />
        <Input
          name="modal-email"
          type="email"
          label="Email address"
          placeholder="jane@example.com"
          fullWidth
        />
        <Input name="modal-bio" label="Bio" placeholder="Tell us about yourself…" fullWidth />
      </div>
      <Button slot="footer" variant="secondary" data-modal-close>Cancel</Button>
      <Button slot="footer" variant="primary">Save changes</Button>
    </Modal>

    <Modal id="modal-no-footer" title="Information">
      <p class="text-(--color-text-muted)">
        This modal has no footer slot — useful for informational content where no action is needed.
        Close with the × button, the backdrop, or the ESC key.
      </p>
    </Modal>

    <Drawer id="drawer-right" title="Right Drawer" side="right">
      <div class="flex flex-col gap-4">
        <p class="text-sm text-(--color-text-muted)">
          This drawer slides in from the right. Use it for navigation, filters, or detail panels.
        </p>
        <p class="text-sm text-(--color-text-muted)">
          Close with the × button, Escape, or backdrop click.
        </p>
      </div>
      <Button slot="footer" data-drawer-close variant="secondary" size="md">Cancel</Button>
      <Button slot="footer" variant="primary" size="md">Save</Button>
    </Drawer>

    <Drawer id="drawer-left" title="Left Drawer" side="left">
      <nav class="flex flex-col gap-1">
        <a
          href="#"
          class="rounded-lg px-3 py-2 text-sm font-medium text-(--color-text-base) hover:bg-(--color-bg-surface)"
          >Dashboard</a
        >
        <a
          href="#"
          class="rounded-lg px-3 py-2 text-sm font-medium text-(--color-text-base) hover:bg-(--color-bg-surface)"
          >Projects</a
        >
        <a
          href="#"
          class="rounded-lg px-3 py-2 text-sm font-medium text-(--color-text-base) hover:bg-(--color-bg-surface)"
          >Settings</a
        >
      </nav>
    </Drawer>
  </main>

  <script>
    // * Intersection Observer highlights the active sidebar link as the user scrolls.
    //   AbortController ensures clean re-init after View Transitions.
    let controller: AbortController | null = null

    function initSidebarNav() {
      controller?.abort()
      controller = new AbortController()
      const { signal } = controller

      const links = document.querySelectorAll<HTMLAnchorElement>("aside nav a[href^='#']")
      if (!links.length) return

      const sections = Array.from(links)
        .map((l) => document.querySelector<HTMLElement>(l.getAttribute("href")!))
        .filter(Boolean) as HTMLElement[]

      // * Track active link to update only the previous and next — O(1) instead of O(n).
      let activeLink: HTMLAnchorElement | null = null

      function setActive(id: string) {
        const next = Array.from(links).find((l) => l.getAttribute("href") === `#${id}`) ?? null
        if (next === activeLink) return

        if (activeLink) {
          activeLink.classList.remove("bg-(--color-bg-surface)", "text-(--color-text-base)")
          activeLink.classList.add("text-(--color-text-muted)")
        }
        if (next) {
          next.classList.add("bg-(--color-bg-surface)", "text-(--color-text-base)")
          next.classList.remove("text-(--color-text-muted)")
        }
        activeLink = next
      }

      const observer = new IntersectionObserver(
        (entries) => {
          const visible = entries
            .filter((e) => e.isIntersecting)
            .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top)
          if (visible.length) setActive(visible[0].target.id)
        },
        { rootMargin: "-20% 0px -70% 0px", threshold: 0 }
      )

      sections.forEach((s) => observer.observe(s))

      signal.addEventListener("abort", () => observer.disconnect())
    }

    initSidebarNav()
  </script>

  <script>
    const messages: Record<string, string> = {
      info: "Here is some useful information.",
      success: "Your changes have been saved.",
      warning: "Please review before continuing.",
      error: "Something went wrong. Try again.",
    }

    document.querySelectorAll<HTMLElement>("[data-toast]").forEach((btn) => {
      btn.addEventListener("click", () => {
        const variant = btn.dataset.toast as "info" | "success" | "warning" | "error"
        ;(window as unknown as Record<string, (msg: string, opts: object) => void>).toast?.(
          messages[variant],
          { variant }
        )
      })
    })
  </script>

  <Toast />
  <Footer />
</BaseLayout>
