---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/global/Header.astro";
import Footer from "../components/global/Footer.astro";
import HeroSection from "../components/sections/HeroSection.astro";
import CardGridSection from "../components/sections/CardGridSection.astro";
import { FEATURES } from "../config";
---

<BaseLayout
  title="Home"
  description="Core Boilerplate — a service-agnostic Astro + Tailwind CSS master template."
>
  <Header />

  <main class="flex flex-col gap-16 py-16 flex-1 bg-(--color-bg-base) transition-colors duration-200">
    <HeroSection
      badge="Core Boilerplate v1.0"
      heading="Build Faster,"
      headingAccent="Ship Better"
      subheading="A service-agnostic Astro + Tailwind CSS master template with a semantic design system, dark mode, SEO, and View Transitions baked in."
      primaryCta={{ label: "Get Started", href: "#features" }}
      secondaryCta={{ label: "Docs", href: "https://astro.build/docs" }}
    />
    <CardGridSection
      id="features"
      title="Features"
      items={FEATURES}
    />
  </main>

  <Footer />
</BaseLayout>
