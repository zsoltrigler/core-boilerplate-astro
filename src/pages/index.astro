---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/global/Header.astro";
import Footer from "../components/global/Footer.astro";
import HeroSection from "../components/sections/HeroSection.astro";
import CardGridSection from "../components/sections/CardGridSection.astro";
import Section from "../components/layout/Section.astro";
import Container from "../components/layout/Container.astro";
import Badge from "../components/ui/Badge.astro";
import Button from "../components/ui/Button.astro";
import Card from "../components/ui/Card.astro";
---

<BaseLayout
  title="Home"
  description="Replace this with your site description."
>
  <Header />

  <main class="flex flex-col gap-32 py-16 flex-1">

    <!-- ── Hero ───────────────────────────────────────────────── -->
    <HeroSection>
      <Badge variant="primary" pulse>Your tagline here</Badge>

      <h1 class="text-5xl font-bold tracking-tight text-(--color-text-base) max-w-3xl md:text-6xl lg:text-7xl">
        Your headline
        <span class="text-(--color-brand-primary)">goes here</span>
      </h1>

      <p class="text-xl text-(--color-text-muted) max-w-2xl leading-relaxed">
        Describe your product or service in one or two sentences. What problem does it solve? Who is it for?
      </p>

      <div class="flex flex-wrap items-center justify-center gap-4">
        <Button href="#features" variant="primary" size="lg">
          Get started
          <svg slot="icon-right" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </Button>
        <Button href="/ui" variant="secondary" size="lg">
          View components
        </Button>
      </div>
    </HeroSection>

    <!-- ── Stats ──────────────────────────────────────────────── -->
    <Section>
      <Container>
        <dl class="grid grid-cols-2 gap-8 md:grid-cols-4 text-center">
          {[
            { value: "—",   label: "Stat one" },
            { value: "—",   label: "Stat two" },
            { value: "—",   label: "Stat three" },
            { value: "—",   label: "Stat four" },
          ].map(({ value, label }) => (
            <div class="flex flex-col gap-1">
              <dt class="text-4xl font-black text-(--color-brand-primary)">{value}</dt>
              <dd class="text-sm text-(--color-text-muted)">{label}</dd>
            </div>
          ))}
        </dl>
      </Container>
    </Section>

    <!-- ── Features ───────────────────────────────────────────── -->
    <CardGridSection id="features" columns={3}>
      <div class="col-span-full text-center flex flex-col gap-3 items-center">
        <Badge variant="default">Features</Badge>
        <h2 class="text-3xl font-bold text-(--color-text-base)">Everything you need</h2>
        <p class="text-(--color-text-muted) max-w-xl">Replace this with a short description of your key features or benefits.</p>
      </div>

      <Card title="Feature one" desc="Describe this feature in one or two sentences. What does it do and why does it matter?" shadow>
        <span slot="icon">✦</span>
      </Card>
      <Card title="Feature two" desc="Describe this feature in one or two sentences. What does it do and why does it matter?" shadow>
        <span slot="icon">✦</span>
      </Card>
      <Card title="Feature three" desc="Describe this feature in one or two sentences. What does it do and why does it matter?" shadow>
        <span slot="icon">✦</span>
      </Card>
      <Card title="Feature four" desc="Describe this feature in one or two sentences. What does it do and why does it matter?" shadow>
        <span slot="icon">✦</span>
      </Card>
      <Card title="Feature five" desc="Describe this feature in one or two sentences. What does it do and why does it matter?" shadow>
        <span slot="icon">✦</span>
      </Card>
      <Card title="Feature six" desc="Describe this feature in one or two sentences. What does it do and why does it matter?" shadow>
        <span slot="icon">✦</span>
      </Card>
    </CardGridSection>

    <!-- ── How it works ───────────────────────────────────────── -->
    <Section id="how-it-works">
      <Container size="lg">
        <div class="text-center flex flex-col gap-3 items-center">
          <Badge variant="default">How it works</Badge>
          <h2 class="text-3xl font-bold text-(--color-text-base)">Up and running in 3 steps</h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          {[
            { step: "01", title: "Step one", desc: "Describe the first step your user needs to take.", icon: "→" },
            { step: "02", title: "Step two", desc: "Describe the second step your user needs to take.", icon: "→" },
            { step: "03", title: "Step three", desc: "Describe the third step your user needs to take.", icon: "→" },
          ].map(({ step, title, desc, icon }) => (
            <div class="flex flex-col gap-4">
              <div class="flex items-center gap-3">
                <span class="step-number" data-step={step}></span>
                <span class="text-2xl">{icon}</span>
              </div>
              <h3 class="text-lg font-semibold text-(--color-text-base)">{title}</h3>
              <p class="text-sm text-(--color-text-muted) leading-relaxed">{desc}</p>
            </div>
          ))}
        </div>
      </Container>
    </Section>

    <!-- ── CTA ────────────────────────────────────────────────── -->
    <Section>
      <Container size="md">
        <div class="rounded-2xl bg-(--color-bg-surface) border border-(--color-border-base) p-12 text-center flex flex-col items-center gap-6">
          <Badge variant="primary" pulse>Get started</Badge>
          <h2 class="text-3xl font-bold text-(--color-text-base)">Your call to action</h2>
          <p class="text-(--color-text-muted) max-w-md leading-relaxed">
            One compelling sentence that makes the user want to click the button below.
          </p>
          <div class="flex flex-wrap justify-center gap-4">
            <Button href="#" variant="primary" size="lg">Primary action</Button>
            <Button href="#" variant="secondary" size="lg">Secondary action</Button>
          </div>
        </div>
      </Container>
    </Section>

  </main>

  <Footer />
</BaseLayout>
