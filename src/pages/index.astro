---
import BaseLayout from "../layouts/BaseLayout.astro"
import Header from "../components/global/Header.astro"
import Footer from "../components/global/Footer.astro"
import Section from "../components/layout/Section.astro"
import Container from "../components/layout/Container.astro"
import Badge from "../components/ui/Badge.astro"
import Button from "../components/ui/Button.astro"
import Card from "../components/ui/Card.astro"
import Alert from "../components/ui/Alert.astro"
import Input from "../components/ui/Input.astro"
import CodeWindow from "../components/ui/CodeWindow.astro"
import { Code } from "astro:components"
import { createCssVariablesTheme } from "shiki"
import { SITE, SOCIAL_LINKS } from "../config"

const codeTheme = createCssVariablesTheme({ variablePrefix: "--shiki-" })

const github = SOCIAL_LINKS.find((l) => l.platform === "GitHub")

const stats = [
  {
    label: "WCAG AA",
    desc: "Bad color contrast breaks the build",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
  },
  {
    label: "Dark mode",
    desc: "System preference, toggle, persisted",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9z"/></svg>`,
  },
  {
    label: "Deploy anywhere",
    desc: "Vercel, Netlify, Cloudflare — one env var",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 19V5M5 12l7-7 7 7"/></svg>`,
  },
]
---

<BaseLayout
  title="Home"
  description="Production-ready Astro 7 + Tailwind 4 boilerplate with dark mode, WCAG AA enforcement, SEO, and a perfect Lighthouse score."
>
  <Header />

  <main id="main-content" class="flex flex-1 flex-col">
    <!-- ── Hero ─────────────────────────────────────────────────────── -->
    <Section class="relative overflow-hidden">
      <!-- Top accent line -->
      <div class="absolute inset-x-0 top-0 h-1 bg-(--color-brand-primary)"></div>

      <!-- Radial glow -->
      <div
        class="pointer-events-none absolute inset-0"
        style="background: radial-gradient(ellipse 70% 70% at 70% 50%, color-mix(in srgb, var(--color-brand-primary) 10%, transparent) 0%, transparent 70%);"
      >
      </div>

      <Container class="relative z-10">
        <div class="grid grid-cols-1 gap-12 py-24 lg:grid-cols-2 lg:items-center">
          <!-- Left: text -->
          <div class="flex flex-col gap-6">
            <div>
              <Badge variant="info" pulse>Astro 7 · Tailwind 4</Badge>
            </div>

            <h1 class="text-5xl font-bold leading-tight text-(--color-text-base)">{SITE.name}</h1>

            <p class="max-w-md text-lg leading-relaxed text-(--color-text-muted)">
              Dark mode, WCAG AA enforcement, SEO, and a perfect Lighthouse score — wired up before you write a single line.
            </p>

            <div class="h-0.5 w-14 rounded bg-(--color-brand-primary)"></div>

            <div class="flex flex-wrap gap-3">
              <Button href="/ui" variant="primary" size="md">
                Browse components
                <svg
                  slot="icon-right"
                  xmlns="http://www.w3.org/2000/svg"
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"></path></svg
                >
              </Button>

              {
                github && (
                  <Button href={github.href} variant="secondary" size="md" external>
                    <Fragment slot="icon-left" set:html={github.icon} />
                    View on GitHub
                  </Button>
                )
              }
            </div>
          </div>

          <!-- Right: code snippet -->
          <div class="hidden lg:block">
            <CodeWindow label="src/config.ts">
              <Code
                code={`// ← Your single source of truth
export const SITE = {
  name: "Your Site",
  lang: "en",
}

export const COLORS = {
  brandPrimary: "#4f46e5",
  dark: {
    brandPrimary: "#6366f1",
  },
}`}
                lang="ts"
                theme={codeTheme}
                class="overflow-x-auto p-5 text-sm leading-relaxed [&_code]:font-mono"
              />
            </CodeWindow>
          </div>
        </div>
      </Container>
    </Section>

    <!-- ── Stats bar ─────────────────────────────────────────────────── -->
    <Section class="bg-(--color-bg-surface)">
      <Container>
        <div class="grid grid-cols-1 gap-6 py-8 sm:grid-cols-3">
          {
            stats.map((s) => (
              <div class="flex flex-col items-center gap-3 text-center">
                <span class="text-(--color-brand-primary)">
                  <Fragment set:html={s.icon} />
                </span>

                <div class="flex flex-col gap-1">
                  <span class="text-sm font-semibold text-(--color-text-base)">{s.label}</span>
                  <span class="text-xs text-(--color-text-muted)">{s.desc}</span>
                </div>
              </div>
            ))
          }
        </div>
      </Container>
    </Section>

    <!-- ── What's included ──────────────────────────────────────────── -->
    <Section id="features" class="scroll-mt-20">
      <Container>
        <div class="flex flex-col gap-8 py-20">
          <div class="flex flex-col gap-2">
            <h2 class="text-2xl font-bold text-(--color-text-base)">What's included</h2>

            <p class="text-(--color-text-muted)">Everything you need — nothing you don't.</p>
          </div>

          <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
            <Card
              title="UI Components"
              desc="Button, Card, Badge, Alert, IconButton, Input, Modal — ready to use."
              hover
            >
              <svg
                slot="icon"
                xmlns="http://www.w3.org/2000/svg"
                width="22"
                height="22"
                viewBox="0 0 24 24"
                fill="none"
                stroke="var(--color-brand-primary)"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
                ><path d="M3 5a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"
                ></path><path
                  d="M13 5a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v4a2 2 0 0 1-2 2h-4a2 2 0 0 1-2-2z"
                ></path><path
                  d="M3 15a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"
                ></path><path
                  d="M13 15a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v4a2 2 0 0 1-2 2h-4a2 2 0 0 1-2-2z"
                ></path></svg
              >
            </Card>

            <Card
              title="Dark mode"
              desc="System preference + manual toggle, persisted in localStorage."
              hover
            >
              <svg
                slot="icon"
                xmlns="http://www.w3.org/2000/svg"
                width="22"
                height="22"
                viewBox="0 0 24 24"
                fill="none"
                stroke="var(--color-brand-primary)"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9z"></path></svg
              >
            </Card>

            <Card
              title="Design tokens"
              desc="Brand colors, typography and spacing via CSS variables."
              hover
            >
              <svg
                slot="icon"
                xmlns="http://www.w3.org/2000/svg"
                width="22"
                height="22"
                viewBox="0 0 24 24"
                fill="none"
                stroke="var(--color-brand-primary)"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
                ><circle cx="13.5" cy="6.5" r="2.5"></circle><circle cx="19" cy="17" r="2.5"
                ></circle><circle cx="6.5" cy="17" r="2.5"></circle><path
                  d="M14.5 8.5 19 14.5M12 9l-5.5 6M6.5 14.5l6-9"></path></svg
              >
            </Card>

            <Card
              title="TypeScript"
              desc="Strict mode, typed component props, zero config needed."
              hover
            >
              <svg
                slot="icon"
                xmlns="http://www.w3.org/2000/svg"
                width="22"
                height="22"
                viewBox="0 0 24 24"
                fill="none"
                stroke="var(--color-brand-primary)"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
                ><path
                  d="M15 17.5c.32.32.754.5 1.207.5h.543c.69 0 1.25-.56 1.25-1.25v-.25a1.5 1.5 0 0 0-1.5-1.5 1.5 1.5 0 0 1-1.5-1.5v-.25C15 12.56 15.56 12 16.25 12h.543c.453 0 .887.18 1.207.5"
                ></path><path d="M9 12h4m-2 0v5.5"></path><rect
                  x="3"
                  y="4"
                  width="18"
                  height="16"
                  rx="2"></rect></svg
              >
            </Card>

            <Card
              title="Layout primitives"
              desc="Section and Container components with sensible defaults."
              hover
            >
              <svg
                slot="icon"
                xmlns="http://www.w3.org/2000/svg"
                width="22"
                height="22"
                viewBox="0 0 24 24"
                fill="none"
                stroke="var(--color-brand-primary)"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
                ><rect x="3" y="3" width="18" height="18" rx="2"></rect><path d="M3 9h18M9 21V9"
                ></path></svg
              >
            </Card>

            <Card title="SEO ready" desc="Meta tags, Open Graph, sitemap, canonical URL and robots.txt." hover>
              <svg
                slot="icon"
                xmlns="http://www.w3.org/2000/svg"
                width="22"
                height="22"
                viewBox="0 0 24 24"
                fill="none"
                stroke="var(--color-brand-primary)"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
                ><circle cx="11" cy="11" r="8"></circle><path d="m21 21-4.35-4.35"></path></svg
              >
            </Card>
          </div>
        </div>
      </Container>
    </Section>

    <!-- ── Component preview ────────────────────────────────────────── -->
    <Section>
      <Container>
        <div class="flex flex-col gap-8 py-20">
          <div class="flex items-end justify-between">
            <div class="flex flex-col gap-2">
              <h2 class="text-2xl font-bold text-(--color-text-base)">Components</h2>

              <p class="text-(--color-text-muted)">A quick look at what's ready to use.</p>
            </div>

            <Button href="/ui" variant="ghost" size="sm">See all →</Button>
          </div>

          <!-- Showcase frame -->
          <CodeWindow label="Component showcase">
            <!-- Frame content -->
            <div class="flex flex-col gap-10 p-6">
              <!-- Buttons -->
              <div class="flex flex-col gap-3">
                <p class="text-xs font-semibold uppercase tracking-wider text-(--color-text-muted)">
                  Button
                </p>

                <div class="flex flex-wrap gap-3">
                  <Button variant="primary">Primary</Button>
                  <Button variant="secondary">Secondary</Button>
                  <Button variant="ghost">Ghost</Button>
                  <Button variant="danger">Danger</Button>
                  <Button variant="primary" disabled>Disabled</Button>
                </div>
              </div>

              <!-- Badges -->
              <div class="flex flex-col gap-3">
                <p class="text-xs font-semibold uppercase tracking-wider text-(--color-text-muted)">
                  Badge
                </p>

                <div class="flex flex-wrap gap-2">
                  <Badge variant="default">Default</Badge>
                  <Badge variant="primary">Primary</Badge>
                  <Badge variant="success">Success</Badge>
                  <Badge variant="warning">Warning</Badge>
                  <Badge variant="error">Error</Badge>
                  <Badge variant="info">Info</Badge>
                  <Badge variant="info" pulse>Live</Badge>
                </div>
              </div>

              <!-- Alerts -->
              <div class="flex flex-col gap-3">
                <p class="text-xs font-semibold uppercase tracking-wider text-(--color-text-muted)">
                  Alert
                </p>

                <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
                  <Alert variant="info" title="Information">This is an info alert.</Alert>
                  <Alert variant="success" title="Success">Operation completed.</Alert>
                  <Alert variant="warning" title="Warning">Check your settings.</Alert>
                  <Alert variant="error" title="Error" dismissible>Something went wrong.</Alert>
                </div>
              </div>

              <!-- Inputs -->
              <div class="flex flex-col gap-3">
                <p class="text-xs font-semibold uppercase tracking-wider text-(--color-text-muted)">
                  Input
                </p>

                <div class="grid grid-cols-1 gap-4 sm:grid-cols-3">
                  <Input
                    name="preview-default"
                    label="Default"
                    placeholder="Enter value…"
                    fullWidth
                  />

                  <Input
                    name="preview-hint"
                    label="With hint"
                    placeholder="Enter email…"
                    hint="We'll never share your email."
                    fullWidth
                  />

                  <Input
                    name="preview-error"
                    label="With error"
                    value="wrong@"
                    error="Invalid email address."
                    fullWidth
                  />
                </div>
              </div>
            </div>
          </CodeWindow>
        </div>
      </Container>
    </Section>

    <!-- ── Quick start ──────────────────────────────────────────────── -->
    <Section>
      <Container size="md">
        <div class="flex flex-col gap-6 py-20">
          <div class="flex flex-col gap-2 text-center">
            <h2 class="text-2xl font-bold text-(--color-text-base)">Get started in seconds</h2>

            <p class="text-(--color-text-muted)">Clone, install, and start building.</p>
          </div>

          <!-- Code block -->
          <CodeWindow label="Terminal">
            <pre class="overflow-x-auto p-5 text-sm leading-loose"><code><span class="text-(--color-text-muted)"># Clone the repo</span>
<span class="text-(--color-brand-primary)">git clone</span> <span class="text-(--color-text-base)">https://github.com/zsoltrigler/core-boilerplate-astro.git my-project</span>

<span class="text-(--color-text-muted)"># Install dependencies</span>
<span class="text-(--color-brand-primary)">cd</span> <span class="text-(--color-text-base)">my-project</span> <span class="text-(--color-text-muted)">&amp;&amp;</span> <span class="text-(--color-brand-primary)">pnpm install</span>

<span class="text-(--color-text-muted)"># Start the dev server</span>
<span class="text-(--color-brand-primary)">pnpm dev</span></code></pre>
          </CodeWindow>
        </div>
      </Container>
    </Section>
  </main>

  <Footer />
</BaseLayout>
