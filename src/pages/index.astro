---
import BaseLayout from "../layouts/BaseLayout.astro"
import Header from "../components/global/Header.astro"
import ThemeToggle from "../components/global/ThemeToggle.astro"
import Footer from "../components/global/Footer.astro"
import Section from "../components/layout/Section.astro"
import Container from "../components/layout/Container.astro"
import Badge from "../components/ui/Badge.astro"
import Button from "../components/ui/Button.astro"
import Card from "../components/ui/Card.astro"
import Alert from "../components/ui/Alert.astro"
import Input from "../components/ui/Input.astro"
import CodeWindow from "../components/ui/CodeWindow.astro"
import { Icon } from "astro-icon/components"
import { Code } from "astro:components"
import { createCssVariablesTheme } from "shiki"
import { SITE, SOCIAL_LINKS } from "../config"

const codeTheme = createCssVariablesTheme({ variablePrefix: "--shiki-" })

const heroCode = `\
// ← Your single source of truth
export const SITE = {
  name: "Your Site",
  lang: "en",
}

export const COLORS = {
  brandPrimary: "#4f46e5",
  dark: {
    brandPrimary: "#6366f1",
  },
}`

const github = SOCIAL_LINKS.find((l) => l.platform === "GitHub")

const stats = [
  {
    label: "WCAG AA",
    desc: "Bad color contrast breaks the build",
    icon: "line-md:security",
  },
  {
    label: "Dark mode",
    desc: "System preference, toggle, persisted",
    icon: "line-md:moon-loop",
  },
  {
    label: "Deploy anywhere",
    desc: "Vercel, Netlify, Cloudflare — one env var",
    icon: "line-md:cloud-up",
  },
]
---

<BaseLayout
  title="Home"
  description="Production-ready Astro 7 + Tailwind 4 boilerplate with dark mode, WCAG AA enforcement, SEO, and a perfect Lighthouse score."
>
  <Header>
    <ThemeToggle slot="nav-end" />
  </Header>

  <main id="main-content" class="flex flex-1 flex-col">
    <!-- ── Hero ─────────────────────────────────────────────────────── -->
    <Section class="relative overflow-hidden">
      <!-- Top accent line -->
      <div class="absolute inset-x-0 top-0 h-1 bg-(--color-brand-primary)"></div>

      <!-- Radial glow -->
      <div
        class="pointer-events-none absolute inset-0"
        style="background: radial-gradient(ellipse 70% 70% at 70% 50%, color-mix(in srgb, var(--color-brand-primary) 10%, transparent) 0%, transparent 70%);"
      >
      </div>

      <Container class="relative z-10">
        <div class="grid grid-cols-1 gap-12 py-24 lg:grid-cols-2 lg:items-center">
          <!-- Left: text -->
          <div class="flex flex-col gap-6">
            <div>
              <Badge variant="info" pulse>Astro 7 · Tailwind 4</Badge>
            </div>

            <h1 class="text-5xl leading-tight font-bold text-(--color-text-base)">{SITE.name}</h1>

            <p class="max-w-md text-lg leading-relaxed text-(--color-text-muted)">
              Dark mode, WCAG AA enforcement, SEO, and a perfect Lighthouse score — wired up before
              you write a single line.
            </p>

            <div class="h-0.5 w-14 rounded bg-(--color-brand-primary)"></div>

            <div class="flex flex-wrap gap-3">
              <Button href="/ui" variant="primary" size="md">
                Browse components
                <Icon
                  slot="icon-right"
                  name="line-md:chevron-right"
                  width="16"
                  height="16"
                  aria-hidden="true"
                />
              </Button>

              {
                github && (
                  <Button href={github.href} variant="secondary" size="md" external>
                    <Fragment slot="icon-left" set:html={github.icon} />
                    View on GitHub
                  </Button>
                )
              }
            </div>
          </div>

          <!-- Right: code snippet -->
          <div class="hidden lg:block">
            <CodeWindow label="src/config.ts">
              <Code
                code={heroCode}
                lang="ts"
                theme={codeTheme}
                class="overflow-x-auto p-5 text-sm leading-relaxed [&_code]:font-mono"
              />
            </CodeWindow>
          </div>
        </div>
      </Container>
    </Section>

    <!-- ── Stats bar ─────────────────────────────────────────────────── -->
    <Section class="bg-(--color-bg-surface)">
      <Container>
        <div class="grid grid-cols-1 gap-6 py-8 sm:grid-cols-3">
          {
            stats.map((s) => (
              <div class="flex flex-col items-center gap-3 text-center">
                <span class="text-(--color-brand-primary)">
                  <Icon name={s.icon} width="20" height="20" aria-hidden="true" />
                </span>

                <div class="flex flex-col gap-1">
                  <span class="text-sm font-semibold text-(--color-text-base)">{s.label}</span>
                  <span class="text-xs text-(--color-text-muted)">{s.desc}</span>
                </div>
              </div>
            ))
          }
        </div>
      </Container>
    </Section>

    <!-- ── What's included ──────────────────────────────────────────── -->
    <Section id="features" class="scroll-mt-20">
      <Container>
        <div class="flex flex-col gap-8 py-20">
          <div class="flex flex-col gap-2">
            <h2 class="text-2xl font-bold text-(--color-text-base)">What's included</h2>

            <p class="text-(--color-text-muted)">Everything you need — nothing you don't.</p>
          </div>

          <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
            <Card
              title="UI Components"
              desc="Button, Card, Badge, Alert, IconButton, Input, Modal — ready to use."
              hover
            >
              <Icon
                slot="icon"
                name="line-md:grid-3"
                width="22"
                height="22"
                style="color: var(--color-brand-primary)"
                aria-hidden="true"
              />
            </Card>

            <Card
              title="Dark mode"
              desc="System preference + manual toggle, persisted in localStorage."
              hover
            >
              <Icon
                slot="icon"
                name="line-md:moon-loop"
                width="22"
                height="22"
                style="color: var(--color-brand-primary)"
                aria-hidden="true"
              />
            </Card>

            <Card
              title="Design tokens"
              desc="Brand colors, typography and spacing via CSS variables."
              hover
            >
              <Icon
                slot="icon"
                name="line-md:cog"
                width="22"
                height="22"
                style="color: var(--color-brand-primary)"
                aria-hidden="true"
              />
            </Card>

            <Card
              title="TypeScript"
              desc="Strict mode, typed component props, zero config needed."
              hover
            >
              <Icon
                slot="icon"
                name="line-md:document-code"
                width="22"
                height="22"
                style="color: var(--color-brand-primary)"
                aria-hidden="true"
              />
            </Card>

            <Card
              title="Layout primitives"
              desc="Section and Container components with sensible defaults."
              hover
            >
              <Icon
                slot="icon"
                name="line-md:list-3"
                width="22"
                height="22"
                style="color: var(--color-brand-primary)"
                aria-hidden="true"
              />
            </Card>

            <Card
              title="SEO ready"
              desc="Meta tags, Open Graph, sitemap, canonical URL and robots.txt."
              hover
            >
              <Icon
                slot="icon"
                name="line-md:search"
                width="22"
                height="22"
                style="color: var(--color-brand-primary)"
                aria-hidden="true"
              />
            </Card>
          </div>
        </div>
      </Container>
    </Section>

    <!-- ── Component preview ────────────────────────────────────────── -->
    <Section>
      <Container>
        <div class="flex flex-col gap-8 py-20">
          <div class="flex items-end justify-between">
            <div class="flex flex-col gap-2">
              <h2 class="text-2xl font-bold text-(--color-text-base)">Components</h2>

              <p class="text-(--color-text-muted)">A quick look at what's ready to use.</p>
            </div>

            <Button href="/ui" variant="ghost" size="sm">
              See all
              <Icon
                slot="icon-right"
                name="line-md:chevron-right"
                width="16"
                height="16"
                aria-hidden="true"
              />
            </Button>
          </div>

          <!-- Showcase frame -->
          <CodeWindow label="Component showcase">
            <!-- Frame content -->
            <div class="flex flex-col gap-10 p-6">
              <!-- Buttons -->
              <div class="flex flex-col gap-3">
                <p class="text-xs font-semibold tracking-wider text-(--color-text-muted) uppercase">
                  Button
                </p>

                <div class="flex flex-wrap gap-3">
                  <Button variant="primary">Primary</Button>
                  <Button variant="secondary">Secondary</Button>
                  <Button variant="ghost">Ghost</Button>
                  <Button variant="danger">Danger</Button>
                  <Button variant="primary" disabled>Disabled</Button>
                </div>
              </div>

              <!-- Badges -->
              <div class="flex flex-col gap-3">
                <p class="text-xs font-semibold tracking-wider text-(--color-text-muted) uppercase">
                  Badge
                </p>

                <div class="flex flex-wrap gap-2">
                  <Badge variant="default">Default</Badge>
                  <Badge variant="primary">Primary</Badge>
                  <Badge variant="success">Success</Badge>
                  <Badge variant="warning">Warning</Badge>
                  <Badge variant="error">Error</Badge>
                  <Badge variant="info">Info</Badge>
                  <Badge variant="info" pulse>Live</Badge>
                </div>
              </div>

              <!-- Alerts -->
              <div class="flex flex-col gap-3">
                <p class="text-xs font-semibold tracking-wider text-(--color-text-muted) uppercase">
                  Alert
                </p>

                <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
                  <Alert variant="info" title="Information">This is an info alert.</Alert>
                  <Alert variant="success" title="Success">Operation completed.</Alert>
                  <Alert variant="warning" title="Warning">Check your settings.</Alert>
                  <Alert variant="error" title="Error" dismissible>Something went wrong.</Alert>
                </div>
              </div>

              <!-- Inputs -->
              <div class="flex flex-col gap-3">
                <p class="text-xs font-semibold tracking-wider text-(--color-text-muted) uppercase">
                  Input
                </p>

                <div class="grid grid-cols-1 gap-4 sm:grid-cols-3">
                  <Input
                    name="preview-default"
                    label="Default"
                    placeholder="Enter value…"
                    fullWidth
                  />

                  <Input
                    name="preview-hint"
                    label="With hint"
                    placeholder="Enter email…"
                    hint="We'll never share your email."
                    fullWidth
                  />

                  <Input
                    name="preview-error"
                    label="With error"
                    value="wrong@"
                    error="Invalid email address."
                    fullWidth
                  />
                </div>
              </div>
            </div>
          </CodeWindow>
        </div>
      </Container>
    </Section>

    <!-- ── Quick start ──────────────────────────────────────────────── -->
    <Section>
      <Container size="md">
        <div class="flex flex-col gap-6 py-20">
          <div class="flex flex-col gap-2 text-center">
            <h2 class="text-2xl font-bold text-(--color-text-base)">Get started in seconds</h2>

            <p class="text-(--color-text-muted)">Clone, install, and start building.</p>
          </div>

          <!-- Code block -->
          <CodeWindow label="Terminal">
            <pre
              class="overflow-x-auto p-5 text-sm leading-loose"><code><span class="text-(--color-text-muted)"># Clone the repo</span>
<span class="text-(--color-brand-primary)">git clone</span> <span class="text-(--color-text-base)">https://github.com/zsoltrigler/core-boilerplate-astro.git my-project</span>

<span class="text-(--color-text-muted)"># Install dependencies</span>
<span class="text-(--color-brand-primary)">cd</span> <span class="text-(--color-text-base)">my-project</span> <span class="text-(--color-text-muted)">&amp;&amp;</span> <span class="text-(--color-brand-primary)">pnpm install</span>

<span class="text-(--color-text-muted)"># Start the dev server</span>
<span class="text-(--color-brand-primary)">pnpm dev</span></code></pre>
          </CodeWindow>
        </div>
      </Container>
    </Section>
  </main>

  <Footer />
</BaseLayout>
