---
import "../styles/global.css"
import { SITE, PLACEHOLDER_DESCRIPTION, COLORS, OG_LOCALE_MAP, RTL_LANGUAGES } from "../config"

// * All props have sensible defaults sourced from src/config.ts.
// * Override per-page by passing props directly to <BaseLayout>.
interface Props {
  /** Page title — appended with site name. Omit to show site name only. */
  title?: string
  /** Meta description — max ~160 chars for optimal SEO display. */
  description?: string
  /** Canonical URL; defaults to the current page URL. */
  canonicalUrl?: string
  /** Absolute URL for the OG / Twitter card image. */
  ogImage?: string
  /** Open Graph page type. */
  ogType?: "website" | "article"
  /** Alt text for the OG image — shown by screen readers and some social platforms. */
  ogImageAlt?: string
  /** BCP 47 locale for og:locale (e.g. "en_US", "hu_HU"). Auto-derived from lang if omitted. */
  ogLocale?: string
  /** JSON-LD structured data object — serialized into a <script type="application/ld+json"> tag. */
  jsonLd?: Record<string, unknown>
  /** Article published date (ISO 8601) — only used when ogType is "article". */
  publishedDate?: string
  /** Article modified date (ISO 8601) — only used when ogType is "article". */
  modifiedDate?: string
  /** Author name injected into the <meta name="author"> tag. */
  author?: string
  /** Set to true to add <meta name="robots" content="noindex, nofollow">. */
  noindex?: boolean
  /** BCP 47 language tag for the <html lang> attribute. */
  lang?: string
  /** Text direction for the <html dir> attribute. Auto-derived from lang (via
   * RTL_LANGUAGES in src/config.ts) when omitted — only pass this to override
   * that inference. */
  dir?: "ltr" | "rtl"
  /** Site name appended to the page title and used in OG tags. */
  siteName?: string
  /** Visible text for the keyboard-only "skip to content" link. */
  skipLinkLabel?: string
}

const {
  title = "",
  description = SITE.description,
  canonicalUrl = Astro.url.href,
  ogImage = SITE.ogImage,
  ogImageAlt,
  ogType = "website",
  ogLocale,
  publishedDate,
  modifiedDate,
  author = SITE.author || undefined,
  noindex = false,
  lang = SITE.lang,
  dir,
  siteName = SITE.name,
  skipLinkLabel = "Skip to content",
  jsonLd,
} = Astro.props

// * Derive og:locale from lang if not explicitly provided (e.g. "en" → "en_US").
const resolvedOgLocale = ogLocale ?? OG_LOCALE_MAP[lang] ?? lang

// * Derive dir from lang's base subtag if not explicitly provided (e.g. "ar-EG" → "ar" → "rtl").
const resolvedDir = dir ?? (RTL_LANGUAGES.has(lang.split("-")[0]!) ? "rtl" : "ltr")
// ! lang has no og:locale mapping — og:locale may be invalid. Add it to OG_LOCALE_MAP in src/config.ts.
if (!ogLocale && !OG_LOCALE_MAP[lang] && import.meta.env.DEV) {
  // eslint-disable-next-line no-console
  console.warn(
    `[BaseLayout] No og:locale mapping for lang="${lang}". Add it to OG_LOCALE_MAP in src/config.ts or pass ogLocale explicitly.`
  )
}

const fullTitle = title ? `${title} | ${siteName}` : siteName

// * Relative OG images are resolved against the current request origin —
//   works on any platform without any environment variable configuration.
const resolvedOgImage = ogImage.startsWith("http")
  ? ogImage
  : new URL(ogImage, Astro.url.origin).href

// ! Placeholder description check — blocks CI builds, warns locally.
if (description === PLACEHOLDER_DESCRIPTION) {
  const msg = `[BaseLayout] SITE.description is still the placeholder value. Replace it in src/config.ts before deploying.`
  if (import.meta.env.CI) {
    throw new Error(msg)
  }
  // eslint-disable-next-line no-console
  console.warn(msg)
}

// * Built as a string (rather than a conditionally-rendered <script> element)
//   because prettier-plugin-astro cannot format a multi-statement inline
//   script nested inside a template expression — its brace-matching gets
//   confused by the try/catch block. set:html sidesteps that entirely and
//   is equivalent here: this becomes literal static HTML in the build
//   output, parsed and executed by the browser exactly like an authored
//   <script> tag — unlike a runtime element.innerHTML assignment, this is
//   not something the "scripts inserted via innerHTML don't execute" rule
//   applies to.
// ! Skipped entirely for single-theme templates (SITE.singleTheme) — there
//   is no dark palette or ThemeToggle to switch to, so this would just be
//   dead work on every page load.
const foucScript = SITE.singleTheme
  ? ""
  : `<script>
      ;(function () {
        try {
          const stored = localStorage.getItem("theme")
          const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches
          const dark = stored === "dark" || (!stored && prefersDark)
          if (dark) document.documentElement.classList.add("dark")
        } catch (_) {
          /* localStorage unavailable (e.g. private browsing) */
        }
      })()
    </script>`
---

<!doctype html>
<html lang={lang} dir={resolvedDir}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- FOUC prevention: read theme before first paint (see foucScript above) -->
    <Fragment set:html={foucScript} />

    <!-- Primary Meta -->
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    {author && <meta name="author" content={author} />}
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:locale" content={resolvedOgLocale} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:image" content={resolvedOgImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={ogImageAlt ?? title ?? siteName} />
    {
      ogType === "article" && publishedDate && (
        <meta property="article:published_time" content={publishedDate} />
      )
    }
    {
      ogType === "article" && modifiedDate && (
        <meta property="article:modified_time" content={modifiedDate} />
      )
    }

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={resolvedOgImage} />
    {SITE.twitterHandle && <meta name="twitter:site" content={SITE.twitterHandle} />}

    <!-- Icons & Manifest -->
    <link rel="icon" type="image/svg+xml" href={SITE.favicon} />
    <!-- * PNG fallback for browsers that do not support SVG favicons (~5% share). -->
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon.png" />
    <!-- * 180×180 icon used by iOS when added to home screen. -->
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    {
      SITE.singleTheme ? (
        <meta name="theme-color" content={COLORS.bgBase} />
      ) : (
        <>
          <meta name="theme-color" media="(prefers-color-scheme: light)" content={COLORS.bgBase} />
          <meta
            name="theme-color"
            media="(prefers-color-scheme: dark)"
            content={COLORS.dark?.bgBase ?? COLORS.bgBase}
          />
        </>
      )
    }

    <!-- JSON-LD structured data — pass a jsonLd prop to inject schema.org markup -->
    {
      jsonLd && (
        <script
          is:inline
          type="application/ld+json"
          set:html={JSON.stringify({ ...jsonLd, "@context": "https://schema.org" }).replace(
            /[<>&\u2028\u2029]/g,
            (c) =>
              ({
                "<": "\\u003c",
                ">": "\\u003e",
                "&": "\\u0026",
                "\u2028": "\\u2028",
                "\u2029": "\\u2029",
              })[c]!
          )}
        />
      )
    }

    <!-- Per-page head injection (extra <link>, <script>, JSON-LD, etc.) -->
    <slot name="head" />
  </head>

  <body class="flex min-h-screen flex-col">
    <!-- * Skip to content — visible on focus only; lets keyboard users bypass navigation. -->
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[100] focus:rounded-lg focus:bg-(--color-brand-primary) focus:px-4 focus:py-2 focus:text-sm focus:font-semibold focus:text-(--color-text-inverted) focus:outline-none"
    >
      {skipLinkLabel}
    </a>

    <slot />
  </body>
</html>
