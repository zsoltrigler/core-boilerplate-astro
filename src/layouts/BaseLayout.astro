---
import ClientRouter from "astro/components/ClientRouter.astro"
import "../styles/global.css"
import { SITE, SITE_DEFAULTS, COLORS } from "../config"

// * All props have sensible defaults sourced from src/config.ts.
// * Override per-page by passing props directly to <BaseLayout>.
interface Props {
  /** Page title — appended with site name. Omit to show site name only. */
  title?: string
  /** Meta description — max ~160 chars for optimal SEO display. */
  description?: string
  /** Canonical URL; defaults to the current page URL. */
  canonicalUrl?: string
  /** Absolute URL for the OG / Twitter card image. */
  ogImage?: string
  /** Open Graph page type. */
  ogType?: "website" | "article"
  /** Article published date (ISO 8601) — only used when ogType is "article". */
  publishedDate?: string
  /** Article modified date (ISO 8601) — only used when ogType is "article". */
  modifiedDate?: string
  /** Author name injected into the <meta name="author"> tag. */
  author?: string
  /** Comma-separated keywords for the <meta name="keywords"> tag. */
  keywords?: string
  /** Set to true to add <meta name="robots" content="noindex, nofollow">. */
  noindex?: boolean
  /** BCP 47 language tag for the <html lang> attribute. */
  lang?: string
  /** Site name appended to the page title and used in OG tags. */
  siteName?: string
}

const {
  title = "",
  description = SITE.description,
  canonicalUrl = Astro.url.href,
  ogImage = SITE.ogImage,
  ogType = "website",
  publishedDate,
  modifiedDate,
  author,
  keywords,
  noindex = false,
  lang = SITE.lang,
  siteName = SITE.name,
} = Astro.props

const fullTitle = title ? `${title} | ${siteName}` : siteName

// * Relative OG images are resolved against the current request origin —
//   works on any platform without any environment variable configuration.
const resolvedOgImage = ogImage.startsWith("http")
  ? ogImage
  : new URL(ogImage, Astro.url.origin).href

// ! Warn at runtime when the placeholder description is still in use — it hurts SEO.
if (description === SITE_DEFAULTS.DESCRIPTION) {
  console.warn(
    `[BaseLayout] No custom description set for "${fullTitle}". Using placeholder — this hurts SEO.`
  )
}
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- FOUC prevention: read theme before first paint -->
    <script is:inline>
      ;(function () {
        try {
          var stored = localStorage.getItem("theme")
          var prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches
          var dark = stored === "dark" || (!stored && prefersDark)
          if (dark) document.documentElement.classList.add("dark")
        } catch (_) {}
      })()
    </script>

    <!-- Persist dark class across View Transitions on every page -->
    <script>
      document.addEventListener("astro:before-swap", (e) => {
        if (document.documentElement.classList.contains("dark")) {
          ;(e as TransitionBeforeSwapEvent).newDocument.documentElement.classList.add("dark")
        }
      })
    </script>

    <!-- Primary Meta -->
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    {keywords && <meta name="keywords" content={keywords} />}
    {author && <meta name="author" content={author} />}
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:image" content={resolvedOgImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    {
      ogType === "article" && publishedDate && (
        <meta property="article:published_time" content={publishedDate} />
      )
    }
    {
      ogType === "article" && modifiedDate && (
        <meta property="article:modified_time" content={modifiedDate} />
      )
    }

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={resolvedOgImage} />

    <!-- Icons & Manifest -->
    <link rel="icon" type="image/svg+xml" href={SITE.favicon} />
    <!-- * PNG fallback for browsers that do not support SVG favicons (~5% share). -->
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon.png" />

    <meta name="theme-color" media="(prefers-color-scheme: light)" content={COLORS.bgBase} />

    <meta name="theme-color" media="(prefers-color-scheme: dark)" content={COLORS.dark.bgBase} />

    <!-- View Transitions (Astro 7+ ClientRouter) -->
    <ClientRouter />

    <!-- Per-page head injection (extra <link>, <script>, JSON-LD, etc.) -->
    <slot name="head" />
  </head>

  <body class="flex min-h-screen flex-col">
    <!-- * Skip to content — visible on focus only; lets keyboard users bypass navigation. -->
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-[100] focus:rounded-lg focus:bg-(--color-brand-primary) focus:px-4 focus:py-2 focus:text-sm focus:font-semibold focus:text-white focus:outline-none"
    >
      Skip to content
    </a>

    <slot />
  </body>
</html>
